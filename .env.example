# ============================================
#  MiniMall Docker 环境变量示例
#  复制为 .env 后填入真实值，docker-compose 会自动加载
# ============================================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=ChangeMe_RootPass_2026
MYSQL_PORT=3306
MYSQL_DATABASE=minimall

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_PASSWORD=ChangeMe_RedisPass_2026

# ---------- 后端服务端口 ----------
SERVER_PORT=8081

# ---------- DeepSeek (LLM) ----------
DEEPSEEK_API_KEY=
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# ---------- Embedding (RAG 向量化) ----------
# 留空 = 走本地 TF-IDF 降级方案（精度有限，但离线可用）
EMBEDDING_API_KEY=
# EMBEDDING_API_URL=https://api.deepseek.com/embeddings
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ---------- JWT ----------
# 必须 256 bit 随机字符串，openssl rand -base64 32 生成
JWT_SECRET=ChangeMe_Use256bit_RandomKey_GeneratedBy_openssl
JWT_EXPIRATION=86400000

# ---------- RAG ----------
RAG_ENABLED=true

# ---------- JVM 调优（可选） ----------
# JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75.0 -Xlog:gc*:file=/app/logs/gc.log:time
