<view class="page">
  <view class="header">
    <view class="header-title">🌾 助农活动</view>
    <view class="header-subtitle">参与助农活动，助力乡村振兴</view>
  </view>

  <view class="search-bar">
    <mall-icon type="search" size="32rpx" color="#999" />
    <input
      class="search-input"
      placeholder="搜索活动名称"
      value="{{searchQuery}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
      confirm-type="search"
    />
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <scroll-view scroll-x class="filter-bar" enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{filters}}"
      wx:key="value"
      class="filter-tag {{filterStatus === item.value ? 'active' : ''}}"
      data-value="{{item.value}}"
      bindtap="filterByStatus"
    >{{item.label}}</view>
  </scroll-view>

  <view class="activity-list" wx:if="{{!loading && activities.length > 0}}">
    <view
      class="activity-card"
      wx:for="{{activities}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="card-cover-wrap">
        <image class="card-cover" src="{{item.coverImage}}" mode="aspectFill" />
        <view class="status-badge {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="card-body">
        <view class="card-title">{{item.title}}</view>
        <view class="card-desc">{{item.description}}</view>
        <view class="card-meta">
          <view class="meta-item">
            <mall-icon type="time" size="26rpx" color="#999" />
            <text>{{item.startTime}} ~ {{item.endTime}}</text>
          </view>
          <view class="meta-item">
            <mall-icon type="location" size="26rpx" color="#999" />
            <text>{{item.location}}</text>
          </view>
        </view>
        <view class="card-footer">
          <view class="progress-section">
            <view class="progress-info">
              <text class="progress-num">{{item.currentParticipants || 0}}</text>
              <text>/{{item.maxParticipants || 0}} 人</text>
            </view>
            <view class="progress-bar">
              <view
                class="progress-fill"
                style="width: {{item.maxParticipants > 0 ? (item.currentParticipants / item.maxParticipants * 100) : 0}}%"
              ></view>
            </view>
          </view>
          <view
            class="join-btn {{item.status === 1 ? '' : 'disabled'}}"
            catchtap="{{item.status === 1 ? 'goToDetail' : ''}}"
            data-id="{{item.id}}"
          >{{item.status === 1 ? '立即报名' : item.statusText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{!loading && activities.length > 0}}">
    <text wx:if="{{hasMore}}" bindtap="loadMore">加载更多</text>
    <text wx:else>— 已经到底了 —</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && activities.length === 0}}">
    <mall-icon type="empty" size="120rpx" color="#ccc" />
    <text>暂无活动数据</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
