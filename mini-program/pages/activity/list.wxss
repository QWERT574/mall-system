.page {
  min-height: 100vh;
  background: #f5f6f7;
  padding-bottom: env(safe-area-inset-bottom);
}

.header {
  padding: 30rpx 30rpx 20rpx;
  background: linear-gradient(135deg, #c9956a 0%, #e8b88a 100%);
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.search-bar {
  margin: 20rpx 24rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 12rpx;
}

.search-btn {
  font-size: 26rpx;
  color: #c9956a;
  font-weight: bold;
  padding-left: 16rpx;
  border-left: 1rpx solid #eee;
}

.filter-bar {
  white-space: nowrap;
  padding: 0 24rpx 20rpx;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border-radius: 32rpx;
  margin-right: 16rpx;
  transition: all 0.2s;
}

.filter-tag.active {
  background: linear-gradient(135deg, #c9956a, #e8b88a);
  color: #fff;
  font-weight: bold;
}

.activity-list {
  padding: 0 24rpx;
}

.activity-card {
  background: #fff;
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-cover-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.card-cover {
  width: 100%;
  height: 100%;
}

.status-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}

.status-ongoing {
  background: rgba(76,175,80,0.9);
}

.status-ended {
  background: rgba(158,158,158,0.9);
}

.status-upcoming {
  background: rgba(66,153,225,0.9);
}

.card-body {
  padding: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.card-desc {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  margin-top: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.meta-item text {
  margin-left: 6rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.progress-section {
  flex: 1;
  margin-right: 20rpx;
}

.progress-info {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.progress-num {
  color: #c9956a;
  font-weight: bold;
}

.progress-bar {
  height: 12rpx;
  background: #f0ece8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #c9956a, #e8b88a);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.join-btn {
  padding: 14rpx 36rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #c9956a, #e8b88a);
  font-weight: bold;
  white-space: nowrap;
}

.join-btn.disabled {
  background: #ccc;
  color: #fff;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #bbb;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  color: #ccc;
  font-size: 28rpx;
}

.empty-state text {
  margin-top: 20rpx;
}

.loading-state {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}
