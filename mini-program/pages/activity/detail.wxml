<view class="page">
  <image class="cover" src="{{activity.coverImage}}" mode="aspectFill" wx:if="{{!loading}}" />

  <view class="info-card" wx:if="{{!loading}}">
    <view class="info-header">
      <view class="info-title">{{activity.name}}</view>
      <view class="status-tag {{activity.statusClass}}">{{activity.statusText}}</view>
    </view>
    <view class="info-desc">{{activity.description}}</view>

    <view class="info-row">
      <mall-icon type="time" size="30rpx" color="#c9956a" />
      <text>{{activity.startTimeText}} ~ {{activity.endTimeText}}</text>
    </view>
    <view class="info-row">
      <mall-icon type="location" size="30rpx" color="#c9956a" />
      <text>{{activity.location}}</text>
    </view>
    <view class="info-row">
      <mall-icon type="user" size="30rpx" color="#c9956a" />
      <text>组织者：{{activity.organizer || '未知'}}</text>
    </view>

    <view class="progress-section">
      <view class="progress-header">
        <text>参与人数</text>
        <text class="progress-num"><text class="num-current">{{activity.currentCount || 0}}</text> / {{activity.maxCount || 0}} 人</text>
      </view>
      <view class="progress-bar">
        <view
          class="progress-fill"
          style="width: {{activity.maxCount > 0 ? (activity.currentCount / activity.maxCount * 100) : 0}}%"
        ></view>
      </view>
    </view>

    <view class="type-tags">
      <view
        wx:for="{{activity.typeList || [activity.type]}}"
        wx:key="*this"
        class="type-tag"
      >{{item}}</view>
    </view>
  </view>

  <view class="detail-content" wx:if="{{!loading}}">
    <rich-text nodes="{{activity.content}}" />
  </view>

  <view class="bottom-bar" wx:if="{{!loading}}">
    <view
      class="action-btn {{activity.status !== 1 ? 'disabled' : ''}}"
      bindtap="{{activity.joined ? 'cancelJoin' : 'joinActivity'}}"
    >{{activity.joined ? '取消报名' : '立即报名'}}</view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
