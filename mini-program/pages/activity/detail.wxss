.page {
  min-height: 100vh;
  background: #f5f6f7;
  padding-bottom: 140rpx;
}

.cover {
  width: 100%;
  height: 400rpx;
  display: block;
}

.info-card {
  margin: -40rpx 24rpx 20rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 10;
}

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  line-height: 1.4;
  margin-right: 16rpx;
}

.status-tag {
  flex-shrink: 0;
  padding: 8rpx 22rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}

.status-ongoing {
  background: rgba(76,175,80,0.9);
}

.status-ended {
  background: rgba(158,158,158,0.9);
}

.status-upcoming {
  background: rgba(66,153,225,0.9);
}

.info-desc {
  font-size: 28rpx;
  color: #666;
  margin-top: 20rpx;
  line-height: 1.6;
}

.info-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #555;
  margin-top: 18rpx;
  line-height: 1.5;
}

.info-row text:last-child {
  margin-left: 12rpx;
}

.progress-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f2f2f2;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 14rpx;
}

.progress-num {
  color: #999;
}

.num-current {
  color: #c9956a;
  font-weight: bold;
  font-size: 30rpx;
}

.progress-bar {
  height: 16rpx;
  background: #f0ece8;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #c9956a, #e8b88a);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.type-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.type-tag {
  padding: 8rpx 24rpx;
  background: #faf3eb;
  color: #c9956a;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.detail-content {
  margin: 0 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  justify-content: center;
  z-index: 100;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #c9956a, #e8b88a);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
}

.action-btn.disabled {
  background: #ccc;
}

.loading-state {
  text-align: center;
  padding: 160rpx 0;
  font-size: 28rpx;
  color: #999;
}
