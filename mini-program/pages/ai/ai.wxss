/* AI助手页面样式 */
.ai-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  height: 100%;
  background-color: #f8f5f0;
  /* 使用safe-area-inset-bottom确保底部内容不被刘海或虚拟导航栏遮挡 */
  padding-bottom: env(safe-area-inset-bottom);
}

/* 适配不同机型的聊天内容区域 */
.chat-content {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  background-color: #f8f5f0;
  /* 确保内容不被刘海遮挡 */
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

/* 适配不同机型的输入区域 */
.input-area {
  background-color: #ffffff;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #e7e5e4;
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  /* 确保底部内容不被刘海或虚拟导航栏遮挡 */
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 12rpx rgba(107, 68, 35, 0.1);
}

/* 顶部标题栏 */
.ai-header {
  background-color: #ffffff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #e7e5e4;
  box-shadow: 0 2rpx 12rpx rgba(107, 68, 35, 0.1);
  /* 确保标题栏不被刘海遮挡 */
  padding-top: env(safe-area-inset-top);
  margin-top: env(safe-area-inset-top);
}

/* 优化消息项布局 */
.message-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
  padding: 0 10rpx;
}

/* 优化用户消息布局 */
.message-user {
  flex-direction: row-reverse;
}

/* 优化AI消息布局 */
.ai-message {
  flex-direction: row;
}

/* 优化消息内容宽度 */
.message-content {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  max-width: calc(80% - 20rpx);
  word-wrap: break-word;
  word-break: break-all;
}

/* 优化商品卡片布局 */
.product-cards {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 10rpx;
}

/* 优化商品卡片宽度 */
.product-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(107, 68, 35, 0.1);
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1rpx solid #e7e5e4;
  max-width: 100%;
  box-sizing: border-box;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  text-align: center;
  margin-bottom: 12rpx;
}

.service-type {
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-label {
  font-size: 24rpx;
  color: #666666;
  margin-right: 16rpx;
}

.type-tabs {
  display: flex;
  background-color: #f0f0f0;
  border-radius: 20rpx;
  padding: 4rpx;
}

.type-tab {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  color: #666666;
  cursor: pointer;
  transition: all 0.3s ease;
}

.type-tab.active {
  background-color: #4CAF50;
  color: #ffffff;
  font-weight: bold;
}

/* 聊天内容区域 */
.chat-content {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  background-color: #f5f5f5;
}

/* 系统欢迎消息 */
.message-system {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.system-message {
  background-color: #ffffff;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  max-width: 80%;
}

.system-text {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 40rpx;
  margin-bottom: 16rpx;
}

.system-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.suggestion-item {
  font-size: 26rpx;
  color: #4CAF50;
  background-color: #e7e5e4;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  cursor: pointer;
  border: 1rpx solid #c8e6c9;
  transition: all 0.3s ease;
}

.suggestion-item:active {
  background-color: #c8e6c9;
  transform: scale(0.98);
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

/* 用户消息 */
.message-user {
  flex-direction: row-reverse;
}

.user-message {
  display: flex;
  flex-direction: row-reverse;
  align-items: flex-end;
  max-width: 80%;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-left: 16rpx;
  background-color: #4CAF50;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* AI消息 */
.ai-message {
  display: flex;
  align-items: flex-end;
  max-width: 80%;
}

.ai-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  background-color: #2196F3;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 消息内容 */
.message-content {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  max-width: calc(100% - 80rpx);
  word-wrap: break-word;
  word-break: break-all;
}

.user-content {
  background-color: #4CAF50;
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
}

.ai-content {
  background-color: #ffffff;
  color: #333333;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-text {
  font-size: 28rpx;
  line-height: 40rpx;
}

/* 正在输入提示 */
.typing-content {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #999999;
  margin-right: 8rpx;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.typing-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes typing {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* 输入区域 */
.input-area {
  background-color: #ffffff;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #e0e0e0;
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.input-textarea {
  flex: 1;
  min-height: 80rpx;
  max-height: 200rpx;
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #333333;
  background-color: #f9f9f9;
  resize: none;
}

.input-placeholder {
  color: #999999;
}

.send-btn {
  background-color: #4CAF50;
  color: #ffffff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  border: none;
  min-width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.send-btn:active {
  background-color: #388E3C;
}

.send-btn-disabled {
  background-color: #cccccc;
  color: #ffffff;
  opacity: 0.7;
}

.send-btn:not(.send-btn-disabled):active {
  background-color: #388E3C;
  transform: scale(0.95);
  transition: all 0.1s ease;
}

.send-btn {
  transition: all 0.1s ease;
}

/* 商品卡片样式 */
.product-cards {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1rpx solid #f0f0f0;
}

.product-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.product-card-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.product-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-card-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 8rpx;
}

.product-card-price {
  font-size: 32rpx;
  color: #e53935;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.product-card-stock {
  font-size: 24rpx;
  color: #666666;
}

/* 头像文字样式 */
.avatar-letter {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

/* ============ RAG 升级新增样式 ============ */

/* 头部行布局 */
.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-title {
  margin-bottom: 0;
}

/* RAG 增强徽章 */
.rag-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.rag-badge-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 清空历史按钮 */
.clear-history-btn {
  font-size: 24rpx;
  color: #999999;
  padding: 4rpx 16rpx;
}

.clear-history-btn:active {
  color: #4CAF50;
}

/* 知识来源区域 */
.sources-section {
  margin-top: 16rpx;
  border-top: 1rpx dashed #e0e0e0;
  padding-top: 12rpx;
}

.sources-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.sources-title {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.sources-icon {
  font-size: 24rpx;
}

.sources-title-text {
  font-size: 22rpx;
  color: #667eea;
  font-weight: 600;
}

.sources-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 相似度徽章 */
.score-badge {
  font-size: 20rpx;
  color: #764ba2;
  background-color: #f0e6ff;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.toggle-arrow {
  font-size: 22rpx;
  color: #999999;
}

/* 知识来源列表 */
.sources-list {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.source-item {
  background-color: #f8f9ff;
  border-left: 4rpx solid #667eea;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.source-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.source-type-tag {
  font-size: 20rpx;
  color: #667eea;
  background-color: #e8e3ff;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
}

.source-score {
  font-size: 20rpx;
  color: #999999;
}

.source-title {
  display: block;
  font-size: 24rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.source-content {
  display: block;
  font-size: 22rpx;
  color: #666666;
  line-height: 32rpx;
  max-height: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* 响应耗时元数据 */
.response-meta {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
}

.response-time {
  font-size: 20rpx;
  color: #bbbbbb;
}
