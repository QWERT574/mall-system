/* pages/coupon/index.wxss */
.container { padding: 16px; background: #f9fafb; min-height: 100vh; }
.header { text-align: center; margin-bottom: 20px; }
.title { font-size: 24px; font-weight: 700; color: #1f2937; display: block; }
.subtitle { font-size: 13px; color: #9ca3af; margin-top: 6px; display: block; }
.tabs { display: flex; gap: 6px; background: #f3f4f6; padding: 4px; border-radius: 10px; margin-bottom: 16px; }
.tab { flex: 1; text-align: center; padding: 8px 0; font-size: 13px; color: #6b7280; border-radius: 8px; }
.tab.active { background: #fff; color: #d97706; font-weight: 600; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
.loading, .empty { text-align: center; padding: 60px 0; font-size: 14px; color: #9ca3af; }

.coupon-list { display: flex; flex-direction: column; gap: 12px; }
.coupon-card { display: flex; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); position: relative; }
.coupon-card.claimed { opacity: 0.55; }
.coupon-card.my.used .c-left { background: #bbb !important; }
.coupon-card.my.expired .c-left { background: #ddd !important; }

.c-left { width: 100px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16px 8px; background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff; flex-shrink: 0; }
.c-value { font-size: 28px; font-weight: 800; }
.c-condition { font-size: 11px; opacity: 0.8; margin-top: 4px; }

.c-right { flex: 1; padding: 14px; display: flex; flex-direction: column; gap: 4px; }
.c-name { font-size: 15px; font-weight: 600; color: #1f2937; }
.c-time { font-size: 12px; color: #ef4444; }
.c-desc { font-size: 12px; color: #9ca3af; }
.c-remain { font-size: 12px; color: #9ca3af; }

.c-status { font-size: 12px; padding: 2px 8px; border-radius: 10px; width: fit-content; }
.s-0 { background: #d1fae5; color: #059669; }
.s-1 { background: #f3f4f6; color: #9ca3af; }
.s-2 { background: #f3f4f6; color: #9ca3af; }

.c-claim { position: absolute; right: 12px; bottom: 12px; padding: 6px 16px; background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff; border-radius: 20px; font-size: 13px; font-weight: 600; }
.c-claimed { position: absolute; right: 12px; bottom: 12px; padding: 6px 16px; background: #d1d5db; color: #fff; border-radius: 20px; font-size: 13px; }
