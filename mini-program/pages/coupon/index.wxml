<!--pages/coupon/index.wxml-->
<view class="container">
  <view class="header">
    <text class="title">领券中心</text>
    <text class="subtitle">海量优惠券等你来领</text>
  </view>
  <view class="tabs">
    <view class="tab {{tab==='center'?'active':''}}" bindtap="switchTab" data-tab="center">领券中心</view>
    <view class="tab {{tab==='my'?'active':''}}" bindtap="switchTab" data-tab="my">我的优惠券</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{tab==='center'}}">
    <view wx:if="{{coupons.length===0}}" class="empty">暂无可用优惠券</view>
    <view class="coupon-list" wx:else>
      <view class="coupon-card {{claimedIds[item.id]?'claimed':''}}" wx:for="{{coupons}}" wx:key="id">
        <view class="c-left">
          <text class="c-value" wx:if="{{item.type===1}}">¥{{item.discountValue}}</text>
          <text class="c-value" wx:else>{{item.discountValue}}折</text>
          <text class="c-condition" wx:if="{{item.type===1&&item.threshold>0}}">满{{item.threshold}}元</text>
        </view>
        <view class="c-right">
          <text class="c-name">{{item.name}}</text>
          <text class="c-time">有效期至：{{item.endTimeText}}</text>
          <text class="c-desc" wx:if="{{item.description}}">{{item.description}}</text>
          <text class="c-remain">剩余 {{item.totalCount - item.usedCount}} 张</text>
        </view>
        <view class="c-claim" bindtap="claimCoupon" data-coupon="{{item}}" wx:if="{{!claimedIds[item.id]}}">
          <text>立即领取</text>
        </view>
        <view class="c-claimed" wx:else>
          <text>已领取</text>
        </view>
      </view>
    </view>
  </view>
  <view wx:else>
    <view wx:if="{{myCoupons.length===0}}" class="empty">还没有领取优惠券</view>
    <view class="coupon-list" wx:else>
      <view class="coupon-card my {{item.status===1?'used':item.status===2?'expired':''}}" wx:for="{{myCoupons}}" wx:key="id">
        <view class="c-left">
          <text class="c-value" wx:if="{{item.couponType===1}}">¥{{item.discountValue}}</text>
          <text class="c-value" wx:else>{{item.discountValue}}折</text>
        </view>
        <view class="c-right">
          <text class="c-name">{{item.couponName}}</text>
          <text class="c-time">有效期至：{{item.endTimeText}}</text>
          <text class="c-status s-{{item.status}}">{{item.status===0?'可使用':item.status===1?'已使用':'已过期'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
