.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f3ef;
}

.chat-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #c9956a, #b8855a);
  color: #fff;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.header-left {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.header-status {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.header-status.online {
  color: #a8e6cf;
}

.header-status.offline {
  color: #ffb3b3;
}

.header-right {
  width: 120rpx;
  display: flex;
  justify-content: flex-end;
}

.intervene-btn {
  font-size: 24rpx;
  color: #fff;
  background-color: rgba(255, 255, 255, 0.25);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.session-list {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
}

.session-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.session-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #c9956a;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.session-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.session-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.session-last-msg {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.session-time {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 8rpx;
}

.unread-badge {
  background-color: #e53935;
  border-radius: 16rpx;
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.unread-text {
  font-size: 20rpx;
  color: #fff;
}

.empty-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
  text-align: center;
  line-height: 36rpx;
  padding: 0 60rpx;
}

.messages-area {
  flex: 1;
  overflow-y: scroll;
  padding: 20rpx 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.welcome-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 20rpx;
}

.welcome-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #c9956a;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 40rpx;
}

.message-row {
  display: flex;
  flex-direction: row;
  margin-bottom: 16rpx;
  align-items: flex-start;
}

.msg-system {
  justify-content: center;
}

.system-text {
  font-size: 24rpx;
  color: #999;
  background-color: rgba(0, 0, 0, 0.04);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.msg-user {
  flex-direction: row-reverse;
  justify-content: flex-start;
}

.msg-seller {
  flex-direction: row;
  justify-content: flex-start;
}

.msg-admin {
  flex-direction: row;
  justify-content: flex-start;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
  margin: 0 12rpx;
}

.user-avatar {
  background-color: #c9956a;
}

.seller-avatar {
  background-color: #7eb88a;
}

.admin-avatar {
  background-color: #5b9bd5;
}

.msg-bubble {
  max-width: 70%;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  word-wrap: break-word;
  word-break: break-all;
}

.msg-user-bubble {
  background-color: #c9956a;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.msg-seller-bubble {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #eee;
  border-bottom-left-radius: 6rpx;
}

.msg-content-wrapper {
  display: flex;
  flex-direction: column;
}

.admin-tag {
  font-size: 20rpx;
  color: #5b9bd5;
  background-color: #e8f0fe;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  margin-bottom: 8rpx;
  margin-left: 12rpx;
}

.input-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-field {
  flex: 1;
  height: 72rpx;
  background-color: #f5f3ef;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: #c9956a;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  line-height: 72rpx;
  border: none;
  padding: 0;
}

.send-btn::after {
  border: none;
}
