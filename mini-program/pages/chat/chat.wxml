<view class="chat-page">
  <view class="chat-header">
    <view class="header-left" bindtap="goBack">
      <mall-icon type="back" size="36" color="#fff"></mall-icon>
    </view>
    <view class="header-center">
      <text class="header-title">{{ currentSellerName }}</text>
      <text class="header-status online" wx:if="{{ true }}">在线</text>
      <text class="header-status offline" wx:else>离线</text>
    </view>
    <view class="header-right">
      <text class="intervene-btn" bindtap="applyIntervention">申请介入</text>
    </view>
  </view>

  <view class="session-list" wx:if="{{ !sessionId }}">
    <view
      wx:for="{{ sessionList }}"
      wx:key="id"
      class="session-item"
      bindtap="openSession"
      data-session="{{ item }}"
    >
      <view class="session-avatar">
        <text class="avatar-text">客</text>
      </view>
      <view class="session-info">
        <text class="session-name">{{ item.sellerName || '在线客服' }}</text>
        <text class="session-last-msg">{{ item.lastMessage || '暂无消息' }}</text>
      </view>
      <view class="session-meta">
        <text class="session-time">{{ item.lastTime || '' }}</text>
        <view class="unread-badge" wx:if="{{ item.unreadCount > 0 }}">
          <text class="unread-text">{{ item.unreadCount > 99 ? '99+' : item.unreadCount }}</text>
        </view>
      </view>
    </view>
    <view class="empty-list" wx:if="{{ sessionList.length === 0 }}">
      <view class="empty-icon">💬</view>
      <text class="empty-text">暂无会话记录</text>
      <text class="empty-tip">在下方输入您的问题,系统将为您创建客服会话</text>
    </view>
  </view>

  <scroll-view
    class="messages-area"
    scroll-y="true"
    scroll-into-view="{{ scrollToView }}"
    scroll-with-animation="true"
    wx:if="{{ sessionId }}"
  >
    <view class="welcome-card" wx:if="{{ messages.length === 0 }}">
      <text class="welcome-title">欢迎咨询</text>
      <text class="welcome-desc">{{ currentSellerName }}为您服务，请问有什么可以帮助您的？</text>
    </view>

    <block wx:for="{{ messages }}" wx:key="id">
      <view class="message-row msg-system" wx:if="{{ item.messageType === 0 }}">
        <text class="system-text">{{ item.content }}</text>
      </view>

      <view class="message-row msg-user" wx:elif="{{ item.senderType === 1 }}">
        <view class="msg-avatar user-avatar">
          <text>我</text>
        </view>
        <view class="msg-bubble msg-user-bubble">
          <text>{{ item.content }}</text>
        </view>
      </view>

      <view class="message-row msg-seller" wx:elif="{{ item.senderType === 2 }}">
        <view class="msg-avatar seller-avatar">
          <text>客</text>
        </view>
        <view class="msg-bubble msg-seller-bubble">
          <text>{{ item.content }}</text>
        </view>
      </view>

      <view class="message-row msg-admin" wx:else>
        <view class="msg-avatar admin-avatar">
          <text>管</text>
        </view>
        <view class="msg-content-wrapper">
          <view class="admin-tag">管理员</view>
          <view class="msg-bubble msg-seller-bubble">
            <text>{{ item.content }}</text>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="input-area">
    <input
      class="input-field"
      placeholder="输入消息..."
      value="{{ inputText }}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" bindtap="sendMessage">发送</button>
  </view>
</view>
