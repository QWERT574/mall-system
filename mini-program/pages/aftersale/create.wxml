<!--pages/aftersale/create.wxml-->
<view class="container">
  <view class="header">申请售后</view>

  <view class="order-info" wx:if="{{orderItem}}">
    <text class="label">订单号：#{{orderId}}</text>
    <text class="item-name" wx:if="{{orderItem.items && orderItem.items.length > 0}}">
      商品：{{orderItem.items[0].productName}}
    </text>
  </view>

  <view class="section">
    <text class="section-title">选择售后类型</text>
    <view class="type-list">
      <view class="type-item {{serviceType===1?'active':''}}" bindtap="selectType" data-type="1">
        <text class="type-icon">💰</text>
        <text class="type-name">退货退款</text>
      </view>
      <view class="type-item {{serviceType===2?'active':''}}" bindtap="selectType" data-type="2">
        <text class="type-icon">🔄</text>
        <text class="type-name">换货</text>
      </view>
      <view class="type-item {{serviceType===3?'active':''}}" bindtap="selectType" data-type="3">
        <text class="type-icon">🔧</text>
        <text class="type-name">维修</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">联系电话</text>
    <input class="input" placeholder="请输入联系电话" value="{{contactPhone}}" bindinput="onContactPhoneInput" type="number" maxlength="11" />
  </view>

  <view class="section">
    <text class="section-title">售后原因 <text class="required">*</text></text>
    <textarea class="textarea" placeholder="请详细描述遇到的问题..." value="{{reason}}" bindinput="onReasonInput" maxlength="500" />
  </view>

  <button class="submit-btn" bindtap="submit" disabled="{{submitting}}" loading="{{submitting}}">
    {{submitting?'提交中...':'提交申请'}}
  </button>
</view>
