/* pages/aftersale/detail.wxss */
.container { padding: 16px; background: #f9fafb; min-height: 100vh; }
.loading, .empty { text-align: center; padding: 60px 0; font-size: 14px; color: #9ca3af; }

.status-banner { text-align: center; padding: 24px; border-radius: 14px; margin-bottom: 20px; }
.status-0 { background: #fef3c7; }
.status-1 { background: #dbeafe; }
.status-2 { background: #d1fae5; }
.status-3 { background: #f3f4f6; }
.status-icon { font-size: 36px; display: block; margin-bottom: 8px; }
.status-title { font-size: 20px; font-weight: 700; color: #1f2937; margin-bottom: 4px; }
.status-desc { font-size: 13px; color: #6b7280; }

.section { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 12px; }
.section-title { font-size: 15px; font-weight: 600; color: #374151; margin-bottom: 12px; display: block; padding-bottom: 8px; border-bottom: 1px solid #f3f4f6; }

.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.info-item { font-size: 13px; }
.info-label { color: #9ca3af; margin-right: 8px; }
.price { color: #ef4444; font-weight: 600; }

.reason-box, .result-box { font-size: 14px; color: #374151; line-height: 1.6; padding: 10px; background: #f9fafb; border-radius: 8px; }

.record-item { display: flex; gap: 12px; padding: 8px 0; border-left: 2px solid #d1d5db; padding-left: 14px; position: relative; }
.record-dot { width: 8px; height: 8px; background: #d97706; border-radius: 50%; position: absolute; left: -5px; top: 12px; }
.record-content { flex: 1; }
.record-text { font-size: 13px; color: #374151; display: block; }
.record-time { font-size: 12px; color: #9ca3af; display: block; margin-top: 4px; }

.action-section {
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
}
.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}
.cancel-btn {
  background: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}
.evidence-btn {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #fff;
}
.logistics-btn {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
}
.contact-btn {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.modal-content {
  width: 80%; background: #fff; border-radius: 16rpx;
  padding: 40rpx; max-height: 70vh;
}
.modal-title {
  font-size: 32rpx; font-weight: 700; color: #333;
  display: block; margin-bottom: 30rpx; text-align: center;
}
.modal-textarea {
  width: 100%; height: 200rpx; border: 1rpx solid #e5e5e5;
  border-radius: 12rpx; padding: 20rpx; font-size: 28rpx;
  box-sizing: border-box; margin-bottom: 30rpx;
}
.form-field { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 8rpx; }
.form-input {
  border: 1rpx solid #e5e5e5; border-radius: 12rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; width: 100%;
  box-sizing: border-box;
}
.modal-actions { display: flex; gap: 20rpx; }
.modal-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  text-align: center; border-radius: 12rpx; font-size: 28rpx;
  font-weight: 600; border: none;
}
.modal-btn.cancel { background: #f5f5f5; color: #666; }
.modal-btn.confirm { background: linear-gradient(135deg, #c9956a, #b8855a); color: #fff; }
