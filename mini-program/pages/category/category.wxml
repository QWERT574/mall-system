<view class="bg-page">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="header-title"><mall-icon name="shop" size="md"/> 商品分类</text>
  </view>
  
  <view class="category-container fade-in">
    <!-- 左侧顶级分类 -->
    <view class="top-category-list">
      <view 
        wx:for="{{topCategories}}" 
        wx:key="id" 
        class="category-item {{selectedCategory.id === item.id ? 'active' : ''}}" 
        bindtap="onCategoryChange" 
        data-id="{{item.id}}"
      >
        <text class="category-icon">{{item.icon || '📦'}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
    
    <!-- 右侧商品列表 -->
    <view class="sub-content">
      <!-- 商品列表 -->
      <view class="product-section">
        <!-- 加载状态 -->
        <view wx:if="{{loading}}" class="loading-container">
          <view class="loading-spinner"></view>
          <text class="loading-text">加载中...</text>
        </view>
        
        <!-- 错误提示 -->
        <view wx:elif="{{error}}" class="error-message">
          <text>{{error}}</text>
          <button bindtap="retryLoad" class="btn-secondary" style="margin-top:20rpx">重试</button>
        </view>
        
        <!-- 商品列表 -->
        <block wx:elif="{{productList.length > 0}}">
          <scroll-view class="product-scroll" scroll-y="true" bindscrolltolower="loadMore">
            <view class="product-grid">
              <view wx:for="{{productList}}" wx:key="id" class="item" bindtap="viewProduct" data-id="{{item.id}}">
                <image src="{{item.cover}}" mode="aspectFill" class="product-image"></image>
                <text class="item-name">{{item.name}}</text>
                <text class="item-price">¥{{item.price}}</text>
                <text class="item-stock" wx:if="{{item.stock < 10}}">仅剩{{item.stock}}件</text>
                <text class="item-stock" wx:elif="{{item.stock < 50}}">库存紧张</text>
                <text class="item-stock" wx:else>现货充足</text>
              </view>
            </view>
          </scroll-view>
          
          <!-- 加载更多 -->
          <view class="load-more">
            <block wx:if="{{loading && productList.length > 0}}">
              <text class="loading-text">加载中...</text>
            </block>
            <block wx:elif="{{hasMore}}">
              <text class="load-more-text" bindtap="loadMore">点击加载更多</text>
            </block>
            <block wx:else>
              <text class="no-more-text">没有更多商品了</text>
            </block>
          </view>
        </block>
        
        <!-- 空状态 -->
        <block wx:else>
          <view class="empty-order">
            <text>该分类下暂无商品</text>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>