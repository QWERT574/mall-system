/* 分类页面样式 - 乡村振兴主题 */

page { background: #f7f6f3; }
.bg-page { min-height: 100vh; background: #f7f6f3; }

/* 页面头部 */
.page-header {
  display: flex; align-items: center; justify-content: center;
  padding: 24rpx 24rpx 12rpx;
}
.header-title {
  font-size: 32rpx; font-weight: 700; color: #5a3e2b;
  display: flex; align-items: center; gap: 8rpx;
}

/* 分类容器 */
.category-container {
  display: flex; height: calc(100vh - 180rpx);
  margin: 0 20rpx 20rpx; border-radius: 16rpx;
  overflow: hidden; background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 左侧分类列表 */
.top-category-list {
  width: 170rpx; background: #f5f3ef;
  border-right: 1rpx solid #ebe8e2;
  overflow-y: auto;
}
.category-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 22rpx 10rpx; border-left: 5rpx solid transparent;
  transition: all 0.2s;
}
.category-item:active { opacity: 0.8; }
.category-item.active {
  background: #fff; border-left-color: #c9956a;
}
.category-item.active .category-name { color: #c9956a; font-weight: 700; }
.category-icon { font-size: 32rpx; margin-bottom: 4rpx; }
.category-name {
  font-size: 23rpx; color: #666; font-weight: 500;
  text-align: center; line-height: 1.3;
}

/* 右侧内容区 */
.sub-content {
  flex: 1; display: flex; flex-direction: column;
  background: #fff; overflow: hidden;
  min-width: 0;
}
.product-section { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

/* 商品网格 - 双列瀑布流 */
.product-scroll {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}
.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 10rpx 12rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 商品卡片 */
.item {
  width: 100%;
  background: #fff; border-radius: 12rpx;
  overflow: hidden; margin-bottom: 0;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
}
.item:active { transform: scale(0.97); }

.product-image {
  width: 100%; height: 150rpx; display: block;
  background: #f0ede8;
  padding-bottom: 0 !important;
  max-width: none !important;
  margin-bottom: 0 !important;
  border-radius: 0 !important;
  border: none !important;
  box-shadow: none !important;
}

.product-grid .item .item-name {
  display: block; font-size: 23rpx; color: #333; font-weight: 500;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  padding: 6rpx 10rpx 0; line-height: 1.3;
}

.item-price {
  font-size: 26rpx; color: #e54d42; font-weight: 800;
  padding: 2rpx 10rpx 0;
}

.item-stock {
  display: inline-block; font-size: 18rpx;
  margin: 4rpx 10rpx 8rpx;
  padding: 1rpx 8rpx; border-radius: 5rpx; font-weight: 500;
}

/* 加载/错误/空状态 */
.loading-container {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 100rpx 0;
}
.loading-spinner {
  width: 44rpx; height: 44rpx; border: 3rpx solid #e8e6e3;
  border-top-color: #c9956a; border-radius: 50%;
  animation: spin 0.85s linear infinite; margin-bottom: 16rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 23rpx; color: #bbb; }

.error-message { text-align: center; padding: 80rpx 20rpx; color: #999; font-size: 26rpx; }
.btn-secondary {
  background: linear-gradient(135deg, #c9956a, #b8855a);
  color: #fff; font-size: 26rpx; border-radius: 28rpx;
  padding: 12rpx 40rpx; border: none;
}
.empty-order { text-align: center; padding: 100rpx 20rpx; color: #999; font-size: 26rpx; }

.load-more { text-align: center; padding: 16rpx 0 24rpx; }
.load-more-text { font-size: 24rpx; color: #c9956a; }
.no-more-text { font-size: 21rpx; color: #ccc; }

.fade-in { animation: fadeIn 0.3s ease forwards; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

