/* 购物车页面样式 - 优化排版 */

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 24rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e4d31;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cart-count {
  position: absolute;
  right: 30rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
}

/* 购物车主体 */
.cart-container {
  max-width: 750rpx;
  margin: 0 auto;
}

/* 全选栏 */
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

/* 全选按钮 */
.select-all {
  display: flex;
  align-items: center;
  gap: 10rpx;
  cursor: pointer;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d4a574;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background-color: #d4a574;
  border-color: #d4a574;
}

.check-icon {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.select-all-text {
  font-size: 30rpx;
  color: #333333;
}

.selected-total {
  font-size: 28rpx;
  color: #d4a574;
  font-weight: 600;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(107, 68, 35, 0.1);
  border: 1rpx solid #e7e5e4;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.go-shopping-btn {
  padding: 15rpx 40rpx;
  font-size: 28rpx;
}

/* 收货地址区域 */
.shipping-address-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(107, 68, 35, 0.1);
  border: 1rpx solid #e7e5e4;
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.edit-address-btn {
  display: flex;
  align-items: center;
  gap: 5rpx;
  color: #d4a574;
  font-size: 26rpx;
  cursor: pointer;
}

.edit-text {
  color: #d4a574;
}

.edit-icon {
  font-size: 30rpx;
  color: #d4a574;
}

/* 地址内容 */
.address-content {
  background-color: #faf8f5;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e7e5e4;
}

.address-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.address-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.consignee {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.phone {
  font-size: 28rpx;
  color: #666666;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  word-break: break-all;
}

/* 无地址状态 */
.no-address {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #f8f5f0;
  border: 2rpx dashed #e7e5e4;
  border-radius: 12rpx;
  color: #999999;
  cursor: pointer;
  transition: all 0.3s ease;
}

.no-address:active {
  background-color: #e7e5e4;
}

.no-address-text {
  font-size: 28rpx;
  color: #666666;
}

.no-address-icon {
  font-size: 36rpx;
  color: #d4a574;
}

/* 购物车商品列表 */
.cart-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 购物车商品项 */
.cart-item {
  display: flex;
  align-items: center;
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  padding: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
  gap: 20rpx;
  transition: all 0.3s ease;
}

.cart-item:active {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.12);
}

/* 商品选择框 */
.item-select {
  cursor: pointer;
  flex-shrink: 0;
}

/* 商品图片 */
.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background-color: #faf8f5;
  object-fit: cover;
  border: 2rpx solid #e7e5e4;
  flex-shrink: 0;
}

/* 商品信息 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}

.item-spec {
  font-size: 24rpx;
  color: #999999;
}

.item-price {
  font-size: 32rpx;
  color: #f44336;
  font-weight: bold;
  background: linear-gradient(135deg, #f44336, #ef5350);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.item-stock {
  font-size: 22rpx;
  color: #d4a574;
  background-color: #e7e5e4;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  align-self: flex-start;
}

/* 商品操作区域 */
.item-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.btn-quantity {
  width: 60rpx;
  height: 60rpx;
  background-color: #f8f5f0;
  color: #333333;
  border: 2rpx solid #e7e5e4;
  border-radius: 50%;
  font-size: 36rpx;
  line-height: 56rpx;
  text-align: center;
  padding: 0;
  transition: all 0.3s ease;
}

.btn-quantity:active {
  background-color: #e7e5e4;
  transform: scale(0.95);
}

.quantity {
  font-size: 30rpx;
  min-width: 80rpx;
  text-align: center;
  color: #333333;
  font-weight: 600;
}

/* 删除按钮 */
.btn-remove {
  background-color: #fff5f5;
  color: #f44336;
  border: 1rpx solid #ffebee;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.btn-remove:active {
  background-color: #ffebee;
  transform: scale(0.95);
}

/* 商品小计 */
.item-subtotal {
  font-size: 30rpx;
  color: #f44336;
  font-weight: bold;
  text-align: right;
  margin-top: 10rpx;
}

/* 底部结算栏 */
.bottom-checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx;
  border-top: 2rpx solid #faf8f5;
  box-shadow: 0 -4rpx 12rpx rgba(107, 68, 35, 0.1);
  z-index: 1000;
  /* 适配底部安全区域 */
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.checkout-info {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.total-label {
  font-size: 32rpx;
  color: #333333;
  margin-right: 10rpx;
}

.total-price {
  font-size: 40rpx;
  color: #f44336;
  font-weight: bold;
  background: linear-gradient(135deg, #f44336, #ef5350);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-right: 20rpx;
}

.total-hint {
  font-size: 26rpx;
  color: #999999;
}

.checkout-btn {
  width: 100%;
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 50%, #a6723a 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.35);
  position: relative;
  overflow: hidden;
}

.checkout-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.checkout-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(212, 165, 116, 0.3);
}

.checkout-btn:active::before {
  left: 100%;
}

.checkout-btn:disabled {
  background: linear-gradient(135deg, #c8e6c9 0%, #a5d6a7 100%);
  color: #ffffff;
  cursor: not-allowed;
  box-shadow: none;
}

/* 动画效果 */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
