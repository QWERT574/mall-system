.review-page {
  min-height: 100vh;
  background-color: #f7f6f3;
  padding: 24rpx;
  padding-bottom: 260rpx;
}

.section-card {
  background: white;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0ede8;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.info-label {
  color: #999;
}

.info-value {
  color: #333;
  font-weight: 500;
}

.info-value.total {
  color: #e54d42;
  font-weight: 700;
  font-size: 32rpx;
}

.empty-state {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 28rpx;
}

.review-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed #eee;
}

.review-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.item-header {
  display: flex;
  margin-bottom: 16rpx;
}

.item-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  font-size: 27rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.item-price {
  font-size: 25rpx;
  color: #999;
  margin-top: 6rpx;
}

.star-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.star-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.stars {
  display: flex;
  gap: 4rpx;
}

.star-item {
  font-size: 40rpx;
}

.star-active {
  color: #FF9900;
}

.star-inactive {
  color: #ddd;
}

.comment-area {
  margin-bottom: 16rpx;
}

.comment-textarea {
  width: 100%;
  height: 160rpx;
  background: #f9f8f6;
  border-radius: 10rpx;
  padding: 16rpx;
  font-size: 27rpx;
  box-sizing: border-box;
  color: #333;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
}

.image-upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.upload-img-wrapper {
  position: relative;
}

.upload-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
}

.del-img-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.add-image-btn {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ccc;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #c9956a, #b8855a);
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 44rpx;
  line-height: 88rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.back-btn {
  margin-top: 16rpx;
  width: 100%;
  height: 88rpx;
  background: #f5f3ef;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  line-height: 88rpx;
  border: none;
  margin: 16rpx 0 0 0;
  padding: 0;
}

.back-btn::after {
  border: none;
}