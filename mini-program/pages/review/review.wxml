<view class="review-page">
  <block wx:if="{{loading}}">
    <view class="section-card">
      <view class="empty-state">加载中...</view>
    </view>
  </block>

  <block wx:elif="{{!order}}">
    <view class="section-card">
      <view class="empty-state">订单不存在</view>
    </view>
  </block>

  <block wx:else>
    <view class="section-card">
      <view class="section-title">订单信息</view>
      <view class="info-row">
        <text class="info-label">订单号</text>
        <text class="info-value">{{order.orderSn}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">下单时间</text>
        <text class="info-value">{{order.createdAt}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">订单金额</text>
        <text class="info-value total">¥{{order.totalPrice}}</text>
      </view>
    </view>

    <view class="section-card">
      <view class="section-title">待评价商品</view>

      <view class="review-item" wx:for="{{items}}" wx:key="id" wx:for-index="itemindex" wx:for-item="item">
        <view class="item-header">
          <image class="item-thumb" src="{{item.productImage}}" mode="aspectFill"></image>
          <view class="item-meta">
            <view class="item-name">{{item.productName}}</view>
            <view class="item-price">¥{{item.price}} × {{item.quantity}}</view>
          </view>
        </view>

        <view class="star-row">
          <text class="star-label">评分</text>
          <view class="stars">
            <text
              class="star-item {{idx < item.rating ? 'star-active' : 'star-inactive'}}"
              wx:for="{{[1,2,3,4,5]}}"
              wx:key="*this"
              wx:for-index="idx"
              data-index="{{idx}}"
              data-itemindex="{{itemindex}}"
              bindtap="selectStar"
            >★</text>
          </view>
        </view>

        <view class="comment-area">
          <textarea
            class="comment-textarea"
            placeholder="分享您的使用体验..."
            maxlength="500"
            value="{{item.comment}}"
            data-itemindex="{{itemindex}}"
            bindinput="onCommentInput"
          ></textarea>
          <view class="char-count">{{item.comment.length || 0}}/500</view>
        </view>

        <view class="image-upload-area">
          <view
            class="upload-img-wrapper"
            wx:for="{{item.images}}"
            wx:key="*this"
            wx:for-index="imgindex"
          >
            <image class="upload-img" src="{{item}}" mode="aspectFill"></image>
            <view
              class="del-img-btn"
              data-itemindex="{{itemindex}}"
              data-imgindex="{{imgindex}}"
              bindtap="deleteImage"
            >×</view>
          </view>
          <view
            wx:if="{{item.images.length < 3}}"
            class="add-image-btn"
            data-itemindex="{{itemindex}}"
            bindtap="chooseImage"
          >+</view>
        </view>
      </view>
    </view>

    <view style="height:240rpx;"></view>

    <view class="submit-bar">
      <button class="submit-btn" disabled="{{submitting}}" bindtap="submitReview">
        {{submitting ? '提交中...' : '提交评价'}}
      </button>
      <button class="back-btn" bindtap="goBack">返回</button>
    </view>
  </block>
</view>