<view class="address-page">
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">收货人姓名</text>
      <input
        class="form-input"
        placeholder="请输入收货人姓名"
        value="{{form.consignee}}"
        bindinput="onNameInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">手机号码</text>
      <input
        class="form-input"
        type="number"
        placeholder="请输入手机号码"
        maxlength="11"
        value="{{form.phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">所在地区</text>
      <picker mode="region" value="{{[form.province, form.city, form.district]}}" bindchange="onRegionChange">
        <view class="form-input region-picker">{{form.province && form.city && form.district ? form.province + ' ' + form.city + ' ' + form.district : '请选择省/市/区'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">详细地址</text>
      <textarea
        class="form-textarea"
        placeholder="请输入详细地址如门牌号等"
        maxlength="100"
        value="{{form.detail}}"
        bindinput="onDetailInput"
      />
    </view>

    <view class="default-row">
      <text class="default-label">设为默认地址</text>
      <switch checked="{{form.isDefault}}" bindchange="onDefaultChange" color="#c9956a" />
    </view>
  </view>
</view>

<view class="submit-bar">
  <view class="submit-btn" bindtap="saveAddress">保存地址</view>
</view>
