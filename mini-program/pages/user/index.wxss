/* ========== 我的页面 - 现代电商风格 v4 ========== */
.profile-page { min-height: 100vh; background: #f5f3f0; padding-bottom: env(safe-area-inset-bottom); }

/* ---------- 用户卡片（横向布局）---------- */
.user-card {
  background: linear-gradient(135deg, #c9956a 0%, #b8855a 60%, #a8764e 100%);
  margin: 0; border-radius: 0;
  padding: 24rpx 28rpx 32rpx;
}
.card-top-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding-bottom: 20rpx;
}
.card-label { font-size: 34rpx; font-weight: 800; color: #fff; letter-spacing: 2rpx; }
.user-main { display: flex; align-items: center; gap: 24rpx; }
.avatar-box { flex-shrink: 0; }
.avatar-img {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.4);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}
.avatar-placeholder {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.22);
  border: 3rpx solid rgba(255,255,255,0.35);
  display: flex; align-items: center; justify-content: center;
  font-size: 52rpx;
}
.avatar-lg { width: 120rpx; height: 120rpx; font-size: 56rpx; }
.user-meta { flex: 1; overflow: hidden; }
.name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.nickname { font-size: 32rpx; font-weight: 700; color: #fff; max-width: 320rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.vip-tag {
  padding: 2rpx 14rpx; background: rgba(255,215,0,0.9);
  color: #8B6914; font-size: 18rpx; font-weight: 700;
  border-radius: 8rpx; white-space: nowrap;
}
.user-desc { font-size: 23rpx; color: rgba(255,255,255,0.75); margin-bottom: 14rpx; }
.stats-row { display: flex; align-items: center; gap: 0; margin-top: 14rpx; }
.stat-item { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 30rpx; font-weight: 700; color: #fff; line-height: 1.2; }
.stat-label { font-size: 20rpx; color: rgba(255,255,255,0.65); margin-top: 2rpx; }
.stat-divider { width: 1rpx; height: 36rpx; background: rgba(255,255,255,0.18); }

/* 未登录状态 */
.login-area { display: flex; align-items: center; gap: 20rpx; }
.login-right { flex: 1; }
.login-greeting { display: block; font-size: 26rpx; color: rgba(255,255,255,0.7); }
.login-brand { display: block; font-size: 34rpx; font-weight: 800; color: #fff; margin: 4rpx 0 16rpx; letter-spacing: 2rpx; }
.login-btn-sm {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 10rpx 28rpx; background: rgba(255,255,255,0.22);
  color: #fff; font-size: 25rpx; font-weight: 600;
  border-radius: 24rpx; border: 1rpx solid rgba(255,255,255,0.3);
  line-height: 1;
}
.login-btn-sm::after { border: none; }
.login-btn-alt { margin-top: 8rpx; background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); font-weight: 400; }

/* ---------- 区块卡片通用 ---------- */
.section-card {
  margin: 16rpx 20rpx; padding: 24rpx;
  background: #fff; border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.sec-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.sec-title { font-size: 29rpx; font-weight: 700; color: #222; }
.sec-more { display: flex; align-items: center; gap: 4rpx; }
.sec-more text:first-child { font-size: 24rpx; color: #999; }
.more-arrow { font-size: 26rpx; color: #ccc; }

/* ---------- 订单快捷入口 ---------- */
.order-quick { display: flex; justify-content: space-around; }
.oq-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; position: relative; padding: 14rpx 0; }
.oq-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
}
.oq-wait { background: linear-gradient(135deg, #FFF3E0, #FFE0B2); }
.oq-paid { background: linear-gradient(135deg, #E3F2FD, #BBDEFB); }
.oq-ship { background: linear-gradient(135deg, #E8F5E9, #C8E6C9); }
.oq-done { background: linear-gradient(135deg, #FCE4EC, #F8BBD0); }
.oq-icon { font-size: 32rpx; }
.oq-text { font-size: 23rpx; color: #555; font-weight: 500; }
.oq-dot {
  position: absolute; top: 8rpx; right: 4rpx;
  min-width: 30rpx; height: 30rpx; line-height: 30rpx;
  background: #ff4d4f; color: #fff; font-size: 18rpx; font-weight: 700;
  border-radius: 15rpx; text-align: center; padding: 0 8rpx;
}
.oq-red { background: #ff6b35; }

/* ---------- 常用功能网格 ---------- */
.func-grid { display: flex; flex-wrap: wrap; }
.func-item {
  width: 25%; display: flex; flex-direction: column; align-items: center;
  gap: 10rpx; padding: 18rpx 0;
}
.func-icon {
  width: 80rpx; height: 80rpx; border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 34rpx;
}
.bg-blue { background: linear-gradient(135deg, #E3F2FD, #BBDEFB); }
.bg-orange { background: linear-gradient(135deg, #FFF3E0, #FFE0B2); }
.bg-green { background: linear-gradient(135deg, #E8F5E9, #C8E6C9); }
.bg-red { background: linear-gradient(135deg, #FFEBEE, #FFCDD2); }
.bg-yellow { background: linear-gradient(135deg, #FFFDE7, #FFF9C4); }
.bg-purple { background: linear-gradient(135deg, #F3E5F5, #E1BEE7); }
.bg-cyan { background: linear-gradient(135deg, #E0F7FA, #B2EBF2); }
.bg-pink { background: linear-gradient(135deg, #FCE4EC, #F8BBD0); }
.func-name { font-size: 23rpx; color: #444; font-weight: 500; }

/* ---------- 服务列表 ---------- */
.svc-list { overflow: hidden; border-radius: 12rpx; }
.svc-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 26rpx 20rpx; background: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.15s;
}
.svc-item:last-child { border-bottom: none; border-radius: 0 0 12rpx 12rpx; }
.svc-item:first-child { border-radius: 12rpx 12rpx 0 0; }
.svc-item:active { background: #f0f0f0; }
.svc-icon-row { display: flex; align-items: center; gap: 14rpx; }
.svc-ico { font-size: 32rpx; }
.svc-txt { font-size: 28rpx; color: #333; }
.svc-arrow { font-size: 28rpx; color: #ccc; }

/* ---------- 退出登录 ---------- */
.logout-section { padding: 30rpx 40rpx; }
.logout-btn-full {
  width: 100%; height: 84rpx; line-height: 84rpx;
  background: #fff; color: #999; font-size: 28rpx; font-weight: 600;
  border-radius: 42rpx; border: 1rpx solid #eee;
}
.logout-btn-full::after { border: none; }
.logout-btn-full:active { background: #f5f5f5; }

.bottom-safe { height: 20rpx; }

/* ---------- 动画 ---------- */
.fade-in { animation: fadeUp 0.35s ease-out; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(16rpx); } to { opacity: 1; transform: translateY(0); } }
