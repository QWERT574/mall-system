/* 收货地址管理页面样式 */

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 24rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e4d31;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 地址列表 */
.address-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 地址卡片 */
.address-card {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.address-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.recipient {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.phone {
  font-size: 28rpx;
  color: #666;
}

.default-tag {
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.address-content {
  background: rgba(212, 165, 116, 0.06);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.address-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

/* 地址操作栏 */
.address-actions {
  display: flex;
  gap: 12rpx;
}

.action-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.98);
}

.select-item {
  background: rgba(212, 165, 116, 0.1);
  color: #d4a574;
}

.default-item {
  background: rgba(255, 152, 0, 0.1);
  color: #ff9800;
}

.edit-item {
  background: rgba(66, 165, 245, 0.1);
  color: #42a5f5;
}

.delete-item {
  background: rgba(244, 67, 54, 0.1);
  color: #f44336;
}

/* 空地址状态 */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-address-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-address-text {
  font-size: 30rpx;
  color: #999;
}

/* 添加地址按钮 */
.add-address-btn {
  margin: 30rpx 24rpx;
  width: calc(100% - 48rpx);
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.35);
}

.add-address-btn:active {
  transform: scale(0.98);
}

/* 表单样式 */
.address-form {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.cancel-btn {
  font-size: 28rpx;
  color: #999;
  padding: 0;
  margin: 0;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: rgba(212, 165, 116, 0.05);
  border: 1rpx solid rgba(212, 165, 116, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: rgba(212, 165, 116, 0.05);
  border: 1rpx solid rgba(212, 165, 116, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  padding: 28rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}

/* 动画效果 */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.full-page-loading {
  min-height: 100vh;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e7e5e4;
  border-top-color: #d4a574;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-action {
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 60rpx;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}