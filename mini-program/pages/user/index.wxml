<view class="profile-page">
  <!-- 用户信息卡片 - 横向布局 -->
  <view class="user-card">
    <view class="card-top-bar">
      <text class="card-label">个人中心</text>
      <mall-icon name="settings" size="sm" color="rgba(255,255,255,0.7)" bindtap="navigateToSecurity"/>
    </view>

    <block wx:if="{{isLogin}}">
      <view class="user-main">
        <view class="avatar-box">
          <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img" mode="aspectFill"></image>
          <view wx:else class="avatar-placeholder">👤</view>
        </view>
        <view class="user-meta">
          <view class="name-row">
            <text class="nickname">{{userInfo.nickname || '乡农用户'}}</text>
            <view class="vip-tag" wx:if="{{userInfo.isVerified}}">已认证</view>
          </view>
          <text class="user-desc">{{userInfo.phone || '未绑定手机号'}}</text>
          <view class="stats-row">
            <view class="stat-item">
              <text class="stat-num">{{userInfo.orderCount || 0}}</text>
              <text class="stat-label">订单</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
              <text class="stat-num">{{userInfo.couponCount || 0}}</text>
              <text class="stat-label">优惠券</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
              <text class="stat-num">{{userInfo.favoriteCount || 0}}</text>
              <text class="stat-label">收藏</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="login-area">
        <view class="avatar-box">
          <view class="avatar-placeholder avatar-lg">👤</view>
        </view>
        <view class="login-right">
          <text class="login-greeting">Hi，欢迎来到</text>
          <text class="login-brand">乡村振兴</text>
          <button class="login-btn-sm" bindtap="wxLogin">
            <mall-icon name="phone" size="sm"/>
            <text>微信登录</text>
          </button>
          <button class="login-btn-sm login-btn-alt" bindtap="showAccountLogin">
            <text>账号登录</text>
          </button>
        </view>
      </view>
    </block>
  </view>

  <!-- 我的订单快捷入口 -->
  <view class="section-card">
    <view class="sec-header">
      <text class="sec-title">我的订单</text>
      <view class="sec-more" bindtap="goToOrder">
        <text>全部订单</text>
        <text class="more-arrow">›</text>
      </view>
    </view>
    <view class="order-quick">
      <view class="oq-item" bindtap="goToOrder" data-status="0">
        <view class="oq-icon-wrap oq-wait"><text class="oq-icon">💰</text></view>
        <text class="oq-text">待付款</text>
        <view class="oq-dot" wx:if="{{pendingCount > 0}}">{{pendingCount}}</view>
      </view>
      <view class="oq-item" bindtap="goToOrder" data-status="1">
        <view class="oq-icon-wrap oq-paid"><text class="oq-icon">📦</text></view>
        <text class="oq-text">待发货</text>
      </view>
      <view class="oq-item" bindtap="goToOrder" data-status="2">
        <view class="oq-icon-wrap oq-ship"><text class="oq-icon">🚚</text></view>
        <text class="oq-text">待收货</text>
        <view class="oq-dot oq-red" wx:if="{{shippingCount > 0}}">{{shippingCount}}</view>
      </view>
      <view class="oq-item" bindtap="goToOrder" data-status="3">
        <view class="oq-icon-wrap oq-done"><text class="oq-icon">⭐</text></view>
        <text class="oq-text">待评价</text>
      </view>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="section-card">
    <view class="sec-header"><text class="sec-title">常用功能</text></view>
    <view class="func-grid">
      <view class="func-item" bindtap="goToChat">
        <view class="func-icon bg-blue"><text>💬</text></view>
        <text class="func-name">客服聊天</text>
      </view>
      <view class="func-item" bindtap="goToAfterSale">
        <view class="func-icon bg-orange"><text>🔧</text></view>
        <text class="func-name">售后服务</text>
      </view>
      <view class="func-item" bindtap="goToActivity">
        <view class="func-icon bg-green"><text>🎋</text></view>
        <text class="func-name">助农活动</text>
      </view>
      <view class="func-item" bindtap="goToCoupon">
        <view class="func-icon bg-red"><text>🎫</text></view>
        <text class="func-name">领券中心</text>
      </view>
      <view class="func-item" bindtap="goToDiscount">
        <view class="func-icon bg-yellow"><text>🏷️</text></view>
        <text class="func-name">优惠活动</text>
      </view>
      <view class="func-item" bindtap="navigateToAddress">
        <view class="func-icon bg-purple"><text>📍</text></view>
        <text class="func-name">收货地址</text>
      </view>
      <view class="func-item" bindtap="navigateToAI">
        <view class="func-icon bg-cyan"><text>🤖</text></view>
        <text class="func-name">AI助手</text>
      </view>
      <view class="func-item" bindtap="goToOrder">
        <view class="func-icon bg-pink"><text>📋</text></view>
        <text class="func-name">全部订单</text>
      </view>
    </view>
  </view>

  <!-- 服务列表 -->
  <view class="section-card">
    <view class="sec-header"><text class="sec-title">账户与服务</text></view>
    <view class="svc-list">
      <view class="svc-item" bindtap="navigateToProfile">
        <view class="svc-icon-row"><text class="svc-ico">👤</text><text class="svc-txt">个人信息</text></view>
        <text class="svc-arrow">›</text>
      </view>
      <view class="svc-item" bindtap="navigateToSecurity">
        <view class="svc-icon-row"><text class="svc-ico">🔒</text><text class="svc-txt">账户安全</text></view>
        <text class="svc-arrow">›</text>
      </view>
      <view class="svc-item" bindtap="aboutUs">
        <view class="svc-icon-row"><text class="svc-ico">ℹ️</text><text class="svc-txt">关于我们</text></view>
        <text class="svc-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}">
    <button class="logout-btn-full" bindtap="logout">退出登录</button>
  </view>

  <view class="bottom-safe"></view>
</view>

