/* 个人资料页面样式 - 乡村振兴主题 */

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 24rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e4d31;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 页面背景 */
.bg-page {
  background-color: #f5f8f5;
  min-height: 100vh;
}

/* 资料容器 */
.profile-container {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 头像卡片 */
.avatar-card {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(212, 165, 116, 0.1);
  border: 4rpx solid rgba(212, 165, 116, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar-edit-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.4);
  font-size: 24rpx;
}

.avatar-hint {
  font-size: 26rpx;
  color: #999;
}

/* 表单卡片 */
.form-card {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

/* 表单样式 */
.profile-form {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 表单标签 */
.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 表单输入框 */
.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: rgba(212, 165, 116, 0.05);
  border: 1rpx solid rgba(212, 165, 116, 0.1);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

/* 日期选择器样式 */
.form-input-picker {
  width: 100%;
}

/* 表单输入框占位符样式 */
.form-input.placeholder {
  color: #999;
}

/* 性别选择器 */
.radio-group {
  display: flex;
  gap: 30rpx;
}

.radio-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: rgba(212, 165, 116, 0.05);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  font-size: 28rpx;
  color: #666;
}

.radio-option.active {
  background: rgba(212, 165, 116, 0.15);
  border-color: #d4a574;
  color: #d4a574;
  font-weight: 600;
}

.radio-dot {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #999;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.radio-option.active .radio-dot {
  background: #d4a574;
  border-color: #d4a574;
}

.radio-option.active .radio-dot::after {
  content: '';
  display: block;
  width: 14rpx;
  height: 14rpx;
  background: #ffffff;
  border-radius: 50%;
  margin: 5rpx auto;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  padding: 28rpx;
  margin-top: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.35);
}

.save-btn:active {
  transform: scale(0.98);
}

/* 退出登录卡片 */
.logout-card {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.logout-btn {
  width: 100%;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: 600;
  background: rgba(255, 107, 107, 0.08);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.logout-btn:active {
  background: rgba(255, 107, 107, 0.15);
  transform: scale(0.98);
}

/* 淡入动画 */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.full-page-loading {
  min-height: 100vh;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e7e5e4;
  border-top-color: #d4a574;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-action {
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 60rpx;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}