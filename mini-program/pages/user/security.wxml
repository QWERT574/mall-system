<view class="security-page">
  <view class="page-title">🔒 账户安全</view>

  <view class="section-card">
    <view class="security-item" bindtap="changePassword">
      <view class="item-left">
        <mall-icon name="lock" size="md" />
        <text class="item-label">登录密码</text>
      </view>
      <view class="item-right">
        <text class="item-value">{{hasPassword ? '已设置' : '未设置'}}</text>
        <text class="arrow">></text>
      </view>
    </view>

    <view class="security-item" bindtap="bindPhone">
      <view class="item-left">
        <mall-icon name="phone" size="md" />
        <text class="item-label">绑定手机号</text>
      </view>
      <view class="item-right">
        <text class="item-value">{{phone || '未绑定'}}</text>
        <text class="arrow">></text>
      </view>
    </view>

    <view class="security-item" bindtap="bindWechat">
      <view class="item-left">
        <mall-icon name="chat" size="md" />
        <text class="item-label">微信绑定</text>
      </view>
      <view class="item-right">
        <text class="item-value">{{wechatBound ? '已绑定' : '未绑定'}}</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <view class="section-card tips-card">
    <view class="tips-title">安全建议</view>
    <view class="tips-list">
      <view class="tips-item">· 定期更换密码，避免使用简单密码</view>
      <view class="tips-item">· 不在公共设备上保存密码或自动登录</view>
      <view class="tips-item">· 发现账户异常请及时联系客服处理</view>
    </view>
  </view>
</view>
