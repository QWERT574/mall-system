<view class="bg-page">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="header-title">👤 个人资料</text>
  </view>
  
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container full-page-loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
  
  <!-- 错误提示 -->
  <view wx:elif="{{error}}" class="empty-state">
    <text class="empty-icon">❌</text>
    <text class="empty-title">加载失败</text>
    <text class="empty-desc">{{error}}</text>
    <view class="empty-action" bindtap="loadUserInfo">重新加载</view>
  </view>
  
  <!-- 个人信息表单 -->
  <view wx:else class="profile-container">
    <!-- 头像卡片 -->
    <view class="avatar-card fade-in">
      <view class="avatar-section" bindtap="chooseAvatar">
        <view class="avatar-wrapper">
          <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" class="user-avatar" />
          <view class="avatar-edit-badge">
            <text>📷</text>
          </view>
        </view>
        <text class="avatar-hint">点击更换头像</text>
      </view>
    </view>
    
    <!-- 表单卡片 -->
    <view class="form-card fade-in">
      <form bindsubmit="updateUserInfo" class="profile-form">
        <!-- 昵称 -->
        <view class="form-item">
          <text class="form-label">✏️ 昵称</text>
          <input name="nickname" placeholder="请输入昵称" value="{{userInfo.nickname}}" class="form-input" />
        </view>
        
        <!-- 性别 -->
        <view class="form-item">
          <text class="form-label">👨👩 性别</text>
          <view class="radio-group">
            <view 
              class="radio-option {{userInfo.gender === 0 ? 'active' : ''}}" 
              bindtap="selectGender" 
              data-gender="0"
            >
              <view class="radio-dot"></view>
              <text>未知</text>
            </view>
            <view 
              class="radio-option {{userInfo.gender === 1 ? 'active' : ''}}" 
              bindtap="selectGender" 
              data-gender="1"
            >
              <view class="radio-dot"></view>
              <text>男</text>
            </view>
            <view 
              class="radio-option {{userInfo.gender === 2 ? 'active' : ''}}" 
              bindtap="selectGender" 
              data-gender="2"
            >
              <view class="radio-dot"></view>
              <text>女</text>
            </view>
          </view>
          <input type="hidden" name="gender" value="{{userInfo.gender}}" />
        </view>
        
        <!-- 手机号 -->
        <view class="form-item">
          <text class="form-label">📱 手机号</text>
          <input name="phone" placeholder="请输入手机号" type="number" value="{{userInfo.phone || ''}}" class="form-input" />
        </view>
        
        <!-- 邮箱 -->
        <view class="form-item">
          <text class="form-label">📧 邮箱</text>
          <input name="email" placeholder="请输入邮箱" type="text" value="{{userInfo.email || ''}}" class="form-input" />
        </view>
        
        <!-- 生日 -->
        <view class="form-item">
          <text class="form-label">🎂 生日</text>
          <picker mode="date" value="{{birthdayValue}}" start="1900-01-01" end="2024-12-31" bindchange="onBirthdayChange" class="form-input-picker">
            <view class="form-input {{!birthdayDisplay ? 'placeholder' : ''}}">
              {{birthdayDisplay || '请选择生日'}}
            </view>
          </picker>
          <input type="hidden" name="birthday" value="{{birthdayValue}}" />
        </view>
        
        <!-- 保存按钮 -->
        <button form-type="submit" class="btn-primary save-btn">保存修改</button>
      </form>
    </view>
    
    <!-- 退出登录按钮 -->
    <view class="logout-card fade-in">
      <view class="logout-btn" bindtap="logout">
        <text>🚪 退出登录</text>
      </view>
    </view>
  </view>
</view>
