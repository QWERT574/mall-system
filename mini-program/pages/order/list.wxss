

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 24rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e4d31;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.filter-bar {
  display: flex;
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.filter-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
  background: rgba(212, 165, 116, 0.04);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  min-width: 80rpx;
}

.filter-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.filter-label {
  font-size: 24rpx;
}

.filter-item.active {
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.order-item {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.order-item:active {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.12);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-id {
  font-size: 28rpx;
  color: #666;
}

.order-status {
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.order-status.pending {
  background: #fff3cd;
  color: #ff9800;
}

.order-status.paid {
  background: #d4edda;
  color: #52c41a;
}

.order-status.shipped {
  background: #fff7e6;
  color: #1d8cf8;
}

.order-status.completed {
  background: #d1fae5;
  color: #52c41a;
}

.order-content {
  margin-bottom: 20rpx;
}

.order-product {
  display: block;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  word-break: break-all;
}

.order-product text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: block;
  width: 100%;
}

.order-footer {
  display: block;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.order-total {
  display: block;
  margin-bottom: 10rpx;
}

.order-time {
  display: block;
}

.order-total {
  font-size: 32rpx;
  font-weight: bold;
  color: #d4a574;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-actions-container {
  display: block;
  width: 100%;
  margin-top: 20rpx;
  clear: both;
}

.order-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 20rpx;
  justify-content: space-around;
  flex-wrap: nowrap;
  width: 100%;
  clear: both;
  box-sizing: border-box;
  padding: 0 10rpx;
}

.order-actions button {
  width: 30%;
  min-width: 180rpx;
  max-width: 220rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 26rpx;
  text-align: center;
  padding: 0 20rpx;
  flex-shrink: 0;
}

/* 确保订单内容是块级元素，按钮在下方显示 */
.order-item {
  display: block;
  position: relative;
  clear: both;
}

.order-header, .order-content, .order-footer {
  display: block;
  width: 100%;
  clear: both;
}

/* 调整商品信息和总计的布局 */
.order-product {
  display: block;
  width: 100%;
  clear: both;
  margin-bottom: 10rpx;
}

.order-total {
  display: inline-block;
  margin-right: 20rpx;
}

.order-detail-btn {
  margin-top: 20rpx;
  text-align: center;
  width: 100%;
}

.pay-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #d4a574, #b8895a);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
  transition: all 0.3s ease;
}

.pay-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.2);
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #ff6b6b, #f44336);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.cancel-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.2);
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #e0e0e0, #bdbdbd);
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(224, 224, 224, 0.3);
  transition: all 0.3s ease;
}

.btn-secondary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(224, 224, 224, 0.2);
}

.btn-detail {
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #42a5f5, #2196f3);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  width: 100%;
  padding: 0 60rpx;
  box-shadow: 0 3rpx 10rpx rgba(66, 165, 245, 0.3);
  transition: all 0.3s ease;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
}

.btn-detail:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(66, 165, 245, 0.2);
}

.btn-aftersale {
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #f59e0b, #d97706);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  width: 100%;
  padding: 0 60rpx;
  box-shadow: 0 3rpx 10rpx rgba(217, 119, 6, 0.3);
  white-space: nowrap;
}

.btn-review {
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #FF9900, #FF8800);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  width: 100%;
  padding: 0 60rpx;
  box-shadow: 0 3rpx 10rpx rgba(255, 136, 0, 0.3);
  white-space: nowrap;
}

.btn-service {
  height: 80rpx;
  line-height: 80rpx;
  background: #f0ede8;
  color: #8b7355;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  width: 100%;
  padding: 0 60rpx;
  white-space: nowrap;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-action {
  padding: 16rpx 60rpx;
  background: linear-gradient(135deg, #d4a574, #c4956a);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}

.empty-order {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 32rpx;
}
