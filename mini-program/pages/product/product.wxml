<view class="bg-page">
  <!-- 加载状态 -->
  <view wx:if="{{loading && !product.id}}" class="loading-container full-page-loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载商品详情中...</text>
  </view>
  
  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="empty-state">
    <text class="empty-icon">❌</text>
    <text class="empty-title">加载失败</text>
    <text class="empty-desc">{{error}}</text>
    <view class="empty-action" bindtap="loadProductDetail" data-id="{{product.id || ''}}">重新加载</view>
  </view>
  
  <view class="product-detail-container" wx:if="{{!loading || product.id}}">
    <!-- 商品图片 -->
    <view class="product-image-container">
      <image src="{{product.cover}}" mode="aspectFill" class="product-main-image"/>
      <view class="image-overlay">
        <view class="image-badge" wx:if="{{selectedSpec && selectedSpec.stock < 10}}">🔥 仅剩{{selectedSpec.stock}}件</view>
      </view>
    </view>
    
    <!-- 商品基本信息 -->
    <view class="product-info-card fade-in">
      <view class="price-row">
        <text class="price-symbol">¥</text>
        <text class="product-price">{{selectedSpec ? selectedSpec.price : product.price}}</text>
        <view class="sales-badge" wx:if="{{product.sales}}">已售{{product.sales}}件</view>
      </view>
      <text class="product-name">{{product.name}}</text>
      
      <view class="product-tags">
        <view class="tag" wx:if="{{selectedSpec && selectedSpec.stock < 5}}">
          <text>⚠️ 库存紧张</text>
        </view>
        <view class="tag stock-tag">
          <text>📦 库存{{selectedSpec ? selectedSpec.stock : product.stock}}件</text>
        </view>
      </view>
    </view>
    
    <!-- 规格选择 -->
    <view class="card specs-section fade-in" wx:if="{{specs && specs.length > 0}}">
      <text class="section-title">选择规格</text>
      <view class="specs-list">
        <view wx:for="{{specs}}" wx:key="id" class="spec-item {{selectedSpec && selectedSpec.id === item.id ? 'active' : ''}}" bindtap="selectSpec" data-spec="{{item}}">
          <text class="spec-name">{{item.specName}}</text>
          <text class="spec-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
    
    <!-- 数量选择 -->
    <view class="card quantity-section fade-in">
      <text class="section-title">购买数量</text>
      <view class="quantity-selector">
        <button bindtap="decreaseQuantity" class="btn-quantity" disabled="{{quantity <= 1}}">-</button>
        <text class="quantity">{{quantity}}</text>
        <button bindtap="increaseQuantity" class="btn-quantity" disabled="{{quantity >= (selectedSpec ? selectedSpec.stock : product.stock)}}">+</button>
        <text class="quantity-hint" wx:if="{{selectedSpec ? selectedSpec.stock < 10 : product.stock < 10}}">仅剩{{selectedSpec ? selectedSpec.stock : product.stock}}件</text>
      </view>
    </view>
    
    <!-- 商品描述 -->
    <view class="card description-section fade-in">
      <text class="section-title">商品描述</text>
      <text class="desc-content">{{product.description}}</text>
    </view>
    
    <!-- 底部操作栏 -->
    <view class="bottom-action-bar">
      <!-- 购物车动画元素 -->
      <view class="cart-animation" wx:if="{{showCartAnimation}}" style="transform: translate({{cartAnimationX}}px, {{cartAnimationY}}px); opacity: {{cartAnimationOpacity}};">
        <image src="{{product.cover}}" class="cart-animation-image"/>
      </view>
      
      <!-- 加入购物车按钮 -->
      <button bindtap="addToCart" class="add-to-cart-btn" loading="{{loading}}">
        {{loading ? '加入中...' : '加入购物车'}}
      </button>

      <!-- 立即购买按钮 -->
      <button bindtap="buyNow" class="buy-now-btn" loading="{{buyLoading}}">
        {{buyLoading ? '处理中...' : '立即购买'}}
      </button>
    </view>
  </view>
</view>
