/* 首页样式 - 乡村振兴 电商主题 v4 */

page { background: #f7f6f3; }

.bg-page {
  min-height: 100vh;
  background: #f7f6f3;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 顶部头部 ========== */
.header-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8rpx 28rpx 16rpx;
  background: #fff;
}
.logo { display: flex; align-items: center; gap: 12rpx; }
.logo-emoji {
  font-size: 40rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(180,130,80,0.2));
}
.logo-text { display: flex; flex-direction: column; }
.logo-title {
  font-size: 32rpx; font-weight: 800; color: #5a3e2b;
  letter-spacing: 2rpx; line-height: 1.2;
}
.logo-sub {
  font-size: 19rpx; color: #b8967a; margin-top: 2rpx;
  letter-spacing: 1rpx;
}
.header-icons { display: flex; gap: 14rpx; }
.icon-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #f7f3ec;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.icon-btn:active { background: #ebe4d8; transform: scale(0.94); }

/* ========== 搜索栏 ========== */
.search-bar {
  display: flex; align-items: center;
  margin: 16rpx 24rpx 20rpx;
  padding: 0 24rpx; height: 72rpx;
  background: #fff; border-radius: 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(107,68,35,0.06);
}
.search-icon { margin-right: 12rpx; display: flex; align-items: center; }
.search-input {
  flex: 1; font-size: 26rpx; color: #333;
  height: 72rpx; line-height: 72rpx;
}

/* ========== 轮播图 ========== */
.banner-wrapper {
  position: relative; margin: 0 24rpx 24rpx; border-radius: 20rpx;
  overflow: hidden; box-shadow: 0 6rpx 20rpx rgba(180,130,80,0.18);
}
.banner-badge {
  position: absolute; top: 14rpx; left: 14rpx; z-index: 10;
  background: linear-gradient(135deg, #ff5656, #e84545);
  color: #fff; font-size: 19rpx; padding: 5rpx 16rpx;
  border-radius: 18rpx; font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 2rpx 8rpx rgba(255,86,86,0.35);
}
.banner-swiper { height: 260rpx; }
.banner-image { width: 100%; height: 260rpx; display: block; }

/* ========== 推广 banner（助农/优惠活动）========== */
.banner-promo {
  position: relative;
  width: 100%; height: 260rpx;
  display: flex; align-items: center;
  padding: 0 32rpx; box-sizing: border-box;
  overflow: hidden;
  color: #fff;
}
.banner-promo-decoration {
  position: absolute;
  top: -40rpx; right: -40rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
}
.banner-promo-decoration::after {
  content: '';
  position: absolute;
  bottom: -60rpx; right: 60rpx;
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.banner-promo-content {
  position: relative; z-index: 2;
  display: flex; align-items: center; gap: 20rpx;
  flex: 1;
}
.banner-promo-emoji {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15));
  flex-shrink: 0;
}
.banner-promo-text {
  display: flex; flex-direction: column;
  flex: 1; min-width: 0;
}
.banner-promo-title {
  font-size: 34rpx; font-weight: 800;
  letter-spacing: 3rpx; line-height: 1.2;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}
.banner-promo-sub {
  font-size: 22rpx; margin-top: 8rpx;
  color: rgba(255,255,255,0.88);
  letter-spacing: 1rpx;
}
.banner-promo-arrow {
  font-size: 44rpx; font-weight: 300;
  color: rgba(255,255,255,0.7);
  margin-left: 4rpx;
}
.banner-promo-tag {
  position: absolute; bottom: 16rpx; right: 24rpx;
  padding: 4rpx 14rpx;
  background: rgba(255,255,255,0.22);
  border: 1rpx solid rgba(255,255,255,0.35);
  font-size: 18rpx; font-weight: 800;
  letter-spacing: 2rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(8rpx);
  z-index: 2;
}

/* 助农活动 - 温暖大地色 */
.banner-promo.promo-1 {
  background: linear-gradient(135deg, #c9956a 0%, #a87245 60%, #8a5a30 100%);
}
/* 限时特惠 - 火热红色 */
.banner-promo.promo-2 {
  background: linear-gradient(135deg, #ff6b4a 0%, #e84a2a 60%, #c93515 100%);
}
/* 新人专享 - 清新绿意 */
.banner-promo.promo-3 {
  background: linear-gradient(135deg, #5cb85c 0%, #449d44 60%, #2d7a2d 100%);
}

/* ========== 搜索历史 ========== */
.section-card {
  margin: 0 20rpx 14rpx; padding: 18rpx 20rpx;
  background: #fff; border-radius: 12rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.03);
}
.search-history .history-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx;
}
.history-title { display: flex; align-items: center; gap: 6rpx; font-size: 26rpx; font-weight: 600; color: #333; }
.clear-history { font-size: 23rpx; color: #bbb; }
.history-list { display: flex; flex-wrap: wrap; gap: 10rpx; }
.history-item {
  padding: 7rpx 20rpx; background: #f5f3ef; border-radius: 18rpx;
  font-size: 23rpx; color: #666;
}
.history-tag { color: #c9956a; margin-right: 3rpx; }

/* ========== 加载/错误状态 ========== */
.loading-container {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 120rpx 0;
}
.loading-spinner {
  width: 44rpx; height: 44rpx; border: 3rpx solid #e8e6e3;
  border-top-color: #c9956a; border-radius: 50%;
  animation: spin 0.85s linear infinite; margin-bottom: 16rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 23rpx; color: #bbb; }

.error-container {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 120rpx 40rpx; text-align: center;
}
.error-text { font-size: 26rpx; color: #999; margin-bottom: 20rpx; }
.retry-btn {
  padding: 14rpx 48rpx; background: linear-gradient(135deg, #c9956a, #b8855a);
  color: #fff; font-size: 26rpx; font-weight: 600; border-radius: 28rpx;
}

/* ========== 区块标题 ========== */
.section-header {
  display: flex; align-items: center; justify-content: center;
  padding: 24rpx 0 16rpx; gap: 16rpx;
}
.section-title-line {
  width: 48rpx; height: 2rpx;
  background: linear-gradient(to right, transparent, #c9956a);
  border-radius: 1rpx;
}
.section-header .section-title-line:last-child {
  background: linear-gradient(to left, transparent, #c9956a);
}
.section-title-text {
  font-size: 28rpx; font-weight: 700; color: #5a3e2b;
  letter-spacing: 4rpx;
  display: flex; align-items: center; gap: 8rpx;
}
.section-title-text::before {
  content: ''; width: 6rpx; height: 6rpx;
  background: #c9956a; border-radius: 50%;
}

/* ========== 商品网格（双列布局）========== */
.product-scroll {
  width: 100%;
  /* 留出底部 tab bar 和加载更多区域的空间 */
  height: calc(100vh - 120rpx);
  box-sizing: border-box;
}
.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 0 16rpx 20rpx;
  box-sizing: border-box;
  width: 100%;
}
.item {
  width: 100%;
  background: #fff; border-radius: 14rpx;
  overflow: hidden; margin-bottom: 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}
.item:active { transform: scale(0.97); }

.product-img-wrap {
  position: relative; width: 100%; height: 280rpx;
  background: #f0ede8; overflow: hidden;
}
.product-image {
  width: 100%; height: 280rpx; display: block;
  padding-bottom: 0 !important;
  max-width: none !important;
  margin-bottom: 0 !important;
  border-radius: 0 !important;
  border: none !important;
  box-shadow: none !important;
  object-fit: cover;
}
.stock-tag {
  position: absolute; top: 10rpx; left: 10rpx; z-index: 2;
  padding: 3rpx 12rpx; background: rgba(255,86,86,0.92);
  color: #fff; font-size: 18rpx; font-weight: 600; border-radius: 8rpx;
}
.stock-warn { background: rgba(255,149,0,0.92); }

.product-info { padding: 12rpx 14rpx 14rpx; }
.item-name {
  display: block; font-size: 25rpx; color: #333; font-weight: 500;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  line-height: 1.4; margin-bottom: 8rpx;
}
.price-row { display: flex; align-items: baseline; justify-content: space-between; }
.item-price {
  font-size: 32rpx; color: #e54d42; font-weight: 800;
  line-height: 1.2;
}
.yen { font-size: 22rpx; font-weight: 700; margin-right: 2rpx; }
.item-sales { font-size: 19rpx; color: #bbb; }

/* ========== 加载更多 ========== */
.load-more { text-align: center; padding: 20rpx 0 28rpx; }
.load-more-text { font-size: 24rpx; color: #c9956a; padding: 8rpx 32rpx; }
.no-more-line { width: 100rpx; height: 2rpx; background: #e0ddd8; margin: 0 auto 10rpx; border-radius: 1rpx; }
.no-more-text { font-size: 21rpx; color: #ccc; }

/* ========== 空状态 ========== */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 120rpx 40rpx;
}
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-title { font-size: 28rpx; color: #333; font-weight: 600; margin-bottom: 8rpx; }
.empty-desc { font-size: 23rpx; color: #aaa; margin-bottom: 24rpx; }
.empty-action {
  padding: 12rpx 40rpx; background: linear-gradient(135deg, #c9956a, #b8855a);
  color: #fff; font-size: 25rpx; font-weight: 600; border-radius: 26rpx;
}

/* ========== 动画 ========== */
.fade-in { animation: fadeIn 0.3s ease forwards; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(6rpx); } to { opacity: 1; transform: translateY(0); } }

