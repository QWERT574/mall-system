@import './shared-theme.wxss';

page {
  background: linear-gradient(180deg, var(--bg-page) 0%, var(--bg-page) 30%, var(--color-primary-lighter) 100%);
  min-height: 100vh;
  font-family: 'Noto Sans SC', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.bg-page{
  min-height: 100vh;
  padding: 16rpx;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
  padding-top: calc(16rpx + env(safe-area-inset-top));
}

/* 卡片样式 - 乡村振兴主题 */
.card{
  background: linear-gradient(145deg, var(--bg-card) 0%, var(--surface-raised) 100%);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-glow-sm), 0 1rpx 3rpx rgba(107, 68, 35, 0.04);
  border: 1rpx solid rgba(107, 68, 35, 0.06);
  margin-top: calc(24rpx + env(safe-area-inset-top));
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--gradient-brand);
}

.card::after {
  content: '';
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.06) 0%, transparent 70%);
  border-radius: 50%;
}

/* 商品网格布局 - 乡村振兴主题 */
.product-grid{
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
  /* 确保商品网格不被底部导航栏遮挡 */
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 响应式商品网格 - 根据屏幕宽度调整列数 */
@media (min-width: 600rpx) {
  .product-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 25rpx;
    padding: 15rpx;
  }
}

@media (min-width: 800rpx) {
  .product-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 30rpx;
    padding: 20rpx;
  }
}

/* 底部操作栏样式 - 适配不同机型 */
.bottom-action-bar,
.bottom-checkout-bar{
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx;
  border-top: 1rpx solid #e7e5e4;
  box-shadow: 0 -4rpx 12rpx rgba(107, 68, 35, 0.1);
  z-index: 1000;
  /* 确保底部操作栏不被虚拟导航栏遮挡 */
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 搜索栏样式 - 适配不同机型 */
.search-bar{
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(107, 68, 35, 0.1);
  border: 1rpx solid #e7e5e4;
  /* 确保搜索栏不被刘海遮挡 */
  margin-top: env(safe-area-inset-top);
}

/* 固定搜索栏样式 */
.fixed-search{
  position: sticky;
  top: calc(20rpx + env(safe-area-inset-top));
  z-index: 100;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(107, 68, 35, 0.15);
}

/* 搜索栏占位符，用于避免内容被固定搜索栏遮挡 */
.search-bar-placeholder{
  height: 90rpx;
  margin-bottom: 32rpx;
}

/* 按钮样式 - 乡村振兴主题 */
.btn-primary{
  background: linear-gradient(135deg, #d4a574 0%, #c08b52 50%, #a6723a 100%);
  color: #ffffff;
  padding: 22rpx 40rpx;
  border-radius: 40rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.35), 0 2rpx 4rpx rgba(212, 165, 116, 0.2);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.btn-primary:active{
  transform: scale(0.97);
  box-shadow: 0 3rpx 10rpx rgba(212, 165, 116, 0.3);
}

.btn-primary:active::before {
  left: 100%;
}

.btn-secondary{
  background-color: #ffffff;
  color: #d4a574;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #d4a574;
  font-size: 30rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-secondary:active{
  background-color: #fdf8f1;
  color: #a6723a;
}

/* 商品网格布局 - 乡村振兴主题 */
.product-grid{
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 10rpx;
}

/* 商品卡片样式 - 乡村振兴主题 */
.item{
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(107, 68, 35, 0.06), 0 1rpx 3rpx rgba(107, 68, 35, 0.03);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 1rpx solid rgba(107, 68, 35, 0.04);
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 响应式商品卡片内边距 */
@media (min-width: 600rpx) {
  .item {
    padding: 20rpx;
  }
}

@media (min-width: 800rpx) {
  .item {
    padding: 24rpx;
  }
}

.item:active{
  transform: translateY(-8rpx) scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(107, 68, 35, 0.12), 0 4rpx 8rpx rgba(107, 68, 35, 0.06);
  border-color: rgba(212, 165, 116, 0.2);
}

.product-image{
  width: 100%;
  max-width: 260rpx;
  height: 0;
  padding-bottom: 100%;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(145deg, #faf8f5 0%, #f5f0e8 100%);
  object-fit: cover;
  border: 2rpx solid rgba(107, 68, 35, 0.08);
  background-size: cover;
  background-position: center;
  box-shadow: 0 2rpx 8rpx rgba(107, 68, 35, 0.05);
  transition: all 0.3s ease;
}

.item:active .product-image {
  transform: scale(0.95);
  border-color: rgba(212, 165, 116, 0.2);
}

/* 库存状态样式 - 乡村振兴主题 */
.item-stock{
  font-size: 22rpx;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.item-stock:nth-child(4){
  background-color: #ffebee;
  color: #c62828;
}

.item-stock:nth-child(5){
  background-color: #fff3e0;
  color: #ef6c00;
}

.item-stock:nth-child(6){
  background-color: #e7e5e4;
  color: #6b4423;
}

.item .item-name{
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  height: 88rpx;
  color: #333333;
  line-height: 44rpx;
}

.item .item-price{
  font-size: 36rpx;
  color: #f44336;
  font-weight: bold;
  background: linear-gradient(135deg, #f44336, #ef5350);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-top: -4rpx;
}

/* 搜索栏样式 - 乡村振兴主题 */
.search-bar{
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(107, 68, 35, 0.08), 0 1rpx 3rpx rgba(107, 68, 35, 0.04);
  border: 1rpx solid rgba(107, 68, 35, 0.06);
}

.search-input{
  flex: 1;
  background: linear-gradient(145deg, #faf8f5 0%, #f5f0e8 100%);
  color: #333333;
  border: 1rpx solid rgba(107, 68, 35, 0.08);
  border-radius: 30rpx;
  padding: 18rpx 28rpx;
  font-size: 30rpx;
  margin-right: 16rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(107, 68, 35, 0.04);
}

.search-btn,
.reset-btn{
  padding: 15rpx 25rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  margin-left: 10rpx;
}

/* 购物车样式 - 乡村振兴主题 */
.cart-container{
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cart-header{
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
}

.select-all{
  display: flex;
  align-items: center;
  cursor: pointer;
}

.checkbox{
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d4a574;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 10rpx;
  transition: all 0.3s ease;
}

.checkbox.checked{
  background-color: #d4a574;
  border-color: #d4a574;
}

.check-icon{
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.select-all-text{
  font-size: 30rpx;
  color: #333333;
}

.selected-total{
  font-size: 28rpx;
  color: #d4a574;
  font-weight: 600;
}

/* 空购物车样式 */
.empty-cart{
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  text-align: center;
}

.empty-icon{
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text{
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.go-shopping-btn{
  padding: 15rpx 40rpx;
  font-size: 28rpx;
}

/* 购物车商品列表 */
.cart-items{
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cart-item{
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 20rpx;
}

.item-select{
  cursor: pointer;
}

.item-image{
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background-color: #faf8f5;
  object-fit: cover;
  border: 2rpx solid #e7e5e4;
}

.item-info{
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-info .item-name{
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}

.item-info .item-spec{
  font-size: 24rpx;
  color: #999999;
}

.item-info .item-price{
  font-size: 32rpx;
  color: #f44336;
  font-weight: bold;
  background: linear-gradient(135deg, #f44336, #ef5350);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.item-actions{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.quantity-control{
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.item-actions .btn-quantity{
  width: 60rpx;
  height: 60rpx;
  background-color: #faf8f5;
  color: #333333;
  border: 2rpx solid #e7e5e4;
  border-radius: 50%;
  font-size: 36rpx;
  line-height: 56rpx;
  text-align: center;
  padding: 0;
  transition: all 0.3s ease;
}

.item-actions .btn-quantity:active{
  background-color: #fdf8f1;
  transform: scale(0.95);
}

.item-actions .quantity{
  font-size: 30rpx;
  min-width: 80rpx;
  text-align: center;
  color: #333333;
  font-weight: 600;
}

.item-actions .btn-remove{
  background-color: #fff5f5;
  color: #f44336;
  border: 1rpx solid #ffebee;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.item-actions .btn-remove:active{
  background-color: #ffebee;
  transform: scale(0.95);
}

.item-subtotal{
  font-size: 30rpx;
  color: #f44336;
  font-weight: bold;
  text-align: right;
  margin-top: 10rpx;
}

/* 底部结算栏 */
.bottom-checkout-bar{
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx;
  border-top: 1rpx solid #e7e5e4;
  box-shadow: 0 -4rpx 12rpx rgba(107, 68, 35, 0.08);
  z-index: 1000;
}

.checkout-info{
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.total-label{
  font-size: 32rpx;
  color: #333333;
  margin-right: 10rpx;
}

.total-price{
  font-size: 40rpx;
  color: #f44336;
  font-weight: bold;
  background: linear-gradient(135deg, #f44336, #ef5350);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-right: 20rpx;
}

.total-hint{
  font-size: 26rpx;
  color: #999999;
}

.checkout-btn{
  width: 100%;
  background-image: linear-gradient(90deg, #d4a574, #b8895a);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}

.checkout-btn:active{
  transform: scale(0.98);
  opacity: 0.9;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.2);
}

.checkout-btn:disabled{
  background-image: linear-gradient(90deg, #e8c9a8, #d4a574);
  color: #ffffff;
  cursor: not-allowed;
  box-shadow: none;
}

/* 订单样式 - 乡村振兴主题 */
