  color: #333333;
}

.cancel-btn{
  font-size: 24rpx;
  color: #999999;
  background-color: transparent;
  border: none;
}

.form-item{
  margin-bottom: 20rpx;
}

.form-label{
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.form-input{
  width: 100%;
  padding: 15rpx;
  border: 2rpx solid #e7e5e4;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  background-color: #f8f5f0;
}

.form-textarea{
  width: 100%;
  padding: 15rpx;
  border: 2rpx solid #e7e5e4;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  background-color: #f8f5f0;
  min-height: 120rpx;
  resize: vertical;
}

.save-btn{
  width: 100%;
  margin-top: 20rpx;
}

/* 个人信息表单样式 */
.profile-form{
  margin-bottom: 20rpx;
}

.avatar-item{
  text-align: center;
}

.avatar-container{
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-container .user-avatar{
  cursor: pointer;
  margin-bottom: 10rpx;
}

.avatar-hint{
  font-size: 24rpx;
  color: #999999;
}

.radio-group{
  display: flex;
  gap: 40rpx;
  padding: 10rpx 0;
}

.radio-group label{
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #333333;
}

.logout-btn{
  width: 100%;
  margin-top: 20rpx;
}

/* ========== 首页头部区域样式 ========== */
.header-area {
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-icon {
  font-size: 48rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-text .title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a2f18;
  letter-spacing: 2rpx;
}

.logo-text .subtitle {
  font-size: 22rpx;
  color: #d4a574;
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.1);
  border: 1rpx solid rgba(212, 165, 116, 0.08);
  font-size: 32rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(212, 165, 116, 0.1);
}

/* ========== 快捷分类入口样式 ========== */
.quick-categories {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.08);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.category-item:active {
  background: rgba(212, 165, 116, 0.08);
  transform: scale(1.05);
}

.category-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #faf8f5 0%, #e7e5e4 100%);
  border-radius: 20rpx;
  font-size: 36rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.1);
}

.category-name {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

/* ========== 轮播图包装器样式 ========== */
.banner-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.banner-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  z-index: 20;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
}

/* ========== 搜索栏增强样式 ========== */
.search-bar .search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #d4a574;
}

/* ========== 搜索历史增强样式 ========== */
.search-history {
  background: linear-gradient(145deg, #ffffff 0%, #fdfbf7 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.06);
  border: 1rpx solid rgba(212, 165, 116, 0.06);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.history-icon {
  font-size: 24rpx;
}

.clear-history {
  font-size: 24rpx;
  color: #999999;
  padding: 8rpx 16rpx;
}

.clear-history:active {
  color: #d4a574;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(145deg, #faf8f5 0%, #faf8f5 100%);
  border-radius: 25rpx;
  font-size: 26rpx;
  color: #666666;
  border: 1rpx solid rgba(212, 165, 116, 0.1);
  transition: all 0.3s ease;
}

.history-tag {
  color: #d4a574;
  font-weight: 600;
}

.history-item:active {
  background: rgba(212, 165, 116, 0.15);
  transform: scale(0.98);
}

/* ========== 商品列表标题样式 ========== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #4a2f18;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #d4a574 0%, #b8895a 100%);
  border-radius: 3rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

.section-more:active {
  color: #d4a574;
}

/* ========== 商品价格标签样式 ========== */
.price-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 12rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 107, 0.3);
}

/* ========== 销量标签样式 ========== */
.sales-tag {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  padding: 4rpx 10rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 6rpx;
}

/* ========== 底部导航栏增强样式 ========== */
.tab-bar-active {
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.4);
}

/* ========== 页面加载动画 ========== */
.page-enter {
  animation: pageFadeIn 0.5s ease-out;
}

@keyframes pageFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 空状态增强样式 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.empty-action {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
}

.empty-action:active {
  transform: scale(0.97);
}

/* ========== 悬浮按钮样式 ========== */
.floating-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #d4a574 0%, #b8895a 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(212, 165, 116, 0.4);
  font-size: 40rpx;
  z-index: 1000;
  transition: all 0.3s ease;
}

.floating-btn:active {
  transform: scale(0.9);
}

/* ========== 商品名称渐变效果 ========== */
.item-name-gradient {
  background: linear-gradient(135deg, #4a2f18 0%, #8c5b28 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
