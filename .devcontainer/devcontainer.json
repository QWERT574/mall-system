{
  "name": "乡村振兴农产品电商平台",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "containerEnv": {
    "DB_HOST": "mysql",
    "DB_PORT": "3306",
    "DB_NAME": "minimall",
    "DB_USERNAME": "root",
    "DB_PASSWORD": "123456",
    "REDIS_HOST": "redis",
    "REDIS_PORT": "6379"
  },
  "forwardPorts": [8081, 5173, 5174, 5175, 5176, 3306, 6379],
  "postCreateCommand": "bash .devcontainer/init.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
