# ============================================
# web-mall 生产环境配置
# 构建时由 GitHub Actions 中的 VITE_API_BASE_URL secret 注入
# 也可直接替换下方 URL 为 Render 后端地址
# ============================================
VITE_API_BASE_URL=https://minimall-backend.onrender.com/api
VITE_REQUEST_TIMEOUT=15000
VITE_UPLOAD_MAX_SIZE=5242880
VITE_PAGE_SIZE=20
