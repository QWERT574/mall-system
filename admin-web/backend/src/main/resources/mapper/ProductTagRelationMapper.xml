<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.minimall.mapper.ProductTagRelationMapper">
    <resultMap id="BaseResultMap" type="com.example.minimall.model.ProductTagRelation">
        <result column="product_id" property="productId"/>
        <result column="tag_id" property="tagId"/>
    </resultMap>

    <select id="selectByProductId" resultMap="BaseResultMap">
        SELECT * FROM product_tag_relation
        WHERE product_id = #{productId}
    </select>

    <select id="selectByTagId" resultMap="BaseResultMap">
        SELECT * FROM product_tag_relation
        WHERE tag_id = #{tagId}
    </select>

    <insert id="insert">
        INSERT INTO product_tag_relation (product_id, tag_id)
        VALUES (#{productId}, #{tagId})
    </insert>

    <delete id="deleteByProductId">
        DELETE FROM product_tag_relation
        WHERE product_id = #{productId}
    </delete>

    <delete id="deleteByTagId">
        DELETE FROM product_tag_relation
        WHERE tag_id = #{tagId}
    </delete>
</mapper>
