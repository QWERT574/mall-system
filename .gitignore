# ================================
# 项目级忽略规则
# ================================

# 备份目录
backup_*/
backup_*/
*.bak
*.backup
*.bkp

# 运行时数据 (用户上传/产物/缓存, 应放在源码外)
data/
**/uploads/
!**/uploads/.gitkeep
!**/static/images/

# 日志文件
**/*.log
**/logs/
**/logs/*
!logs/.gitkeep

# 构建产物
**/target/
**/dist/
**/build/

# 依赖目录
**/node_modules/

# 环境配置文件（保留示例文件）
**/.env
!**/.env.example

# 编译产物
**/*.class
**/*.pyc
**/__pycache__/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 配置
.vscode/
.idea/
.trae/
*.iml
*.ipr
*.iws

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~

# 测试文件（可选）
# **/test_*.sql
# **/*_test.sql

# ================================
# 后端特定规则 (Spring Boot + Maven)
# ================================

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Spring Boot
application-*.properties
application-*.yml
!application.yml
!application.properties

# 数据库备份
*.sql.backup
*_backup_*.sql

# ================================
# 前端特定规则 (Vue + Vite/Webpack)
# ================================

# 构建输出
dist/
build/
*.local

# 依赖
node_modules/
npm-debug.log
yarn-error.log
pnpm-debug.log

# 开发环境配置
.env.local
.env.*.local

# 编辑器
*.sublime-project
*.sublime-workspace

# ================================
# 微信小程序特定规则
# ================================

# 开发者工具配置
project.private.config.json
project.private.config.js

# 编译产物
**/.tea/
**/miniprogram_dist/

# ================================
# 数据库相关
# ================================

# 数据库导出文件（大文件）
*.sql.gz
*.sql.bz2

# 临时 SQL 文件（可选）
# *_temp.sql
# *_fix.sql
# *_migration_temp.sql

# ================================
# 文档和报告（可选）
# ================================

# 临时文档
*_draft.md
*_temp.md
*_backup.md

# 报告（保留重要报告，忽略临时报告）
# *_temp_report.md
# *_draft_report.md

# ================================
# 保留重要示例文件
# ================================

# 环境变量示例
!.env.example

# 配置示例
!**/example/
!**/examples/

# 模板文件
*.template
*.tpl
