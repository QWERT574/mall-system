# ============================================
# Docker 构建上下文忽略规则
# 作用：减小 build context，避免 target/.git 等被打进镜像
# ============================================

# 构建产物
target/
**/target/
*.jar
*.war
*.class

# Git
.git/
.gitignore
.gitattributes

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# 日志和临时
**/*.log
logs/
*.tmp
*.swp
*.bak

# 数据目录（运行时挂载卷）
data/
uploads/
**/uploads/

# 测试相关（生产镜像不编译测试）
test/
**/test/

# 文档
README.md
*.md
docs/

# 依赖目录（后端不会有，前端若混在一起需要）
node_modules/

# 环境变量（避免误传）
.env
.env.local
.env.*.local

# Docker 自身
Dockerfile
.dockerignore

# 多媒体（不会被 Java 编译用到）
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.mp4
