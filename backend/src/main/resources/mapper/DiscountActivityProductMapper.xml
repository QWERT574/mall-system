<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.minimall.mapper.DiscountActivityProductMapper">
    <resultMap id="DiscountActivityProductMap" type="com.example.minimall.model.DiscountActivityProduct">
        <id property="id" column="id"/>
        <result property="activityId" column="activity_id"/>
        <result property="productId" column="product_id"/>
        <result property="discountPrice" column="discount_price"/>
        <result property="productName" column="product_name"/>
        <result property="originalPrice" column="original_price"/>
    </resultMap>

    <select id="selectByActivityId" resultMap="DiscountActivityProductMap">
        SELECT dap.*, p.name AS product_name, p.price AS original_price
        FROM discount_activity_product dap
        LEFT JOIN product p ON dap.product_id = p.id
        WHERE dap.activity_id = #{activityId}
    </select>
</mapper>
