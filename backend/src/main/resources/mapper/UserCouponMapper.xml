<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.minimall.mapper.UserCouponMapper">
    <resultMap id="UserCouponWithCouponMap" type="com.example.minimall.model.UserCoupon">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="couponId" column="coupon_id"/>
        <result property="status" column="status"/>
        <result property="usedAt" column="used_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="couponName" column="coupon_name"/>
        <result property="couponType" column="coupon_type"/>
        <result property="threshold" column="threshold"/>
        <result property="discountValue" column="discount_value"/>
        <result property="endTime" column="end_time"/>
    </resultMap>

    <select id="selectByUserIdWithCoupon" resultMap="UserCouponWithCouponMap">
        SELECT uc.*, c.name AS coupon_name, c.type AS coupon_type,
               c.threshold, c.discount_value, c.end_time
        FROM user_coupon uc
        LEFT JOIN coupon c ON uc.coupon_id = c.id
        WHERE uc.user_id = #{userId}
        ORDER BY uc.created_at DESC
    </select>

    <select id="selectByIdWithCoupon" resultMap="UserCouponWithCouponMap">
        SELECT uc.*, c.name AS coupon_name, c.type AS coupon_type,
               c.threshold, c.discount_value, c.end_time
        FROM user_coupon uc
        LEFT JOIN coupon c ON uc.coupon_id = c.id
        WHERE uc.id = #{id}
    </select>
</mapper>
