<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.minimall.mapper.OrdersMapper">
    <select id="selectByUserId" resultMap="OrderWithItemsMap">
        SELECT o.*, oi.id as item_id, oi.product_id, oi.product_name, oi.spec_id, oi.spec_name, oi.price, oi.quantity, oi.order_id
        FROM orders o
        LEFT JOIN order_item oi ON o.id = oi.order_id
        WHERE o.user_id = #{userId}
        ORDER BY o.created_at DESC
    </select>
    
    <select id="selectOrderWithItems" resultMap="OrderWithItemsMap">
        SELECT o.*, oi.id as item_id, oi.product_id, oi.product_name, oi.spec_id, oi.spec_name, oi.price, oi.quantity, oi.order_id,
               l.logistics_company, l.logistics_no, l.status as logistics_status, l.last_update_time as logistics_update_time
        FROM orders o
        LEFT JOIN order_item oi ON o.id = oi.order_id
        LEFT JOIN logistics l ON o.id = l.order_id
        WHERE o.id = #{id}
    </select>
    
    <resultMap id="OrderWithItemsMap" type="com.example.minimall.model.Orders">
        <id property="id" column="id" />
        <result property="orderSn" column="order_no" />
        <result property="userId" column="user_id" />
        <result property="shippingAddressId" column="shipping_address_id" />
        <result property="consignee" column="consignee" />
        <result property="phone" column="phone" />
        <result property="province" column="province" />
        <result property="city" column="city" />
        <result property="district" column="district" />
        <result property="detail" column="detail" />
        <result property="logisticsId" column="logistics_id" />
        <result property="totalPrice" column="total_amount" />
        <result property="status" column="status" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
        <association property="logistics" javaType="com.example.minimall.model.Logistics">
            <id property="id" column="logistics_id" />
            <result property="orderId" column="id" />
            <result property="logisticsCompany" column="logistics_company" />
            <result property="logisticsNo" column="logistics_no" />
            <result property="status" column="logistics_status" />
            <result property="lastUpdateTime" column="logistics_update_time" />
        </association>
        <collection property="items" ofType="com.example.minimall.model.OrderItem">
            <id property="id" column="item_id" />
            <result property="productId" column="product_id" />
            <result property="productName" column="product_name" />
            <result property="specId" column="spec_id" />
            <result property="specName" column="spec_name" />
            <result property="price" column="price" />
            <result property="quantity" column="quantity" />
            <result property="orderId" column="order_id" />
        </collection>
    </resultMap>
</mapper>