<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.minimall.mapper.ProductTagMapper">
    <resultMap id="BaseResultMap" type="com.example.minimall.model.ProductTag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByProductId" resultMap="BaseResultMap">
        SELECT t.* 
        FROM product_tag t
        INNER JOIN product_tag_relation ptr ON t.id = ptr.tag_id
        WHERE ptr.product_id = #{productId}
    </select>
</mapper>
