# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=minimall
DB_USERNAME=root
DB_PASSWORD=your_password_here

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# DeepSeek AI配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# JWT配置
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=86400000
